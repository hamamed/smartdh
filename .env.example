# Copy this file to `.env` and fill it in. NEVER commit `.env`.

# ---- REQUIRED in production ----
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Only this email becomes admin when it signs up. Leave empty and the FIRST
# account to sign up wins — which is unsafe on a public URL.
ADMIN_EMAIL=you@example.com

# Public URL (used for password-reset links). No trailing slash.
APP_URL=https://smartdh.ma

# "production" enables secure cookies and hides error details
NODE_ENV=production

# The app listens here; nginx proxies to it. Keep it on localhost.
PORT=3000

# ---- Optional: real emails (approval, password reset, notifications) ----
# Leave SMTP_HOST empty and emails are just printed to the log instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SmartDH <no-reply@smartdh.ma>"
