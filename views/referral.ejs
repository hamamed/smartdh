<section class="py-4 py-lg-5">
  <div class="container" style="max-width: 640px;">
    <div class="d-flex align-items-center gap-2 mb-4">
      <a href="/dashboard" class="btn btn-outline-secondary btn-icon rounded-circle"><i data-lucide="arrow-left"></i></a>
      <h3 class="fw-bold mb-0 d-flex align-items-center gap-2"><i data-lucide="user-plus" class="text-primary"></i><%= t('invite_title') %></h3>
    </div>

    <%- include("partials/campaign-card", { campaign: campaign, redirectTo: "referral" }) %>

    <!-- Code + total earned -->
    <div class="card border-0 shadow-sm rounded-4 mb-3">
      <div class="card-body text-center p-4">
        <div class="tile-icon ti-mint mx-auto mb-3" style="width:72px;height:72px;font-size:1.9rem"><i data-lucide="user-plus"></i></div>
        <p class="text-muted small mb-4"><%= t('invite_desc') %></p>

        <div class="input-group mb-3">
          <span class="input-group-text"><%= t('your_code') %></span>
          <input class="form-control fw-bold text-center" id="refLink" readonly value="<%= currentUser.referralCode %>">
          <button class="btn btn-outline-primary d-inline-flex align-items-center gap-1" type="button" id="copyRef"><i data-lucide="copy"></i><%= t('btn_copy') %></button>
        </div>

        <div class="p-3 rounded-3 wallet wallet-mint">
          <div class="small d-flex align-items-center justify-content-center gap-1"><i data-lucide="coins"></i><%= t('ref_total') %></div>
          <div class="h4 fw-bold mb-0 mt-1"><%= money(currentUser.referralEarnings) %></div>
        </div>
      </div>
    </div>

    <!-- Tiers -->
    <h6 class="fw-bold mb-3 d-flex align-items-center gap-2"><i data-lucide="network" class="text-primary"></i><%= t('ref_team') %></h6>
    <% const tints = ['coral', 'yellow', 'sky']; %>
    <% tiers.forEach((tier, i) => { %>
      <div class="card border-0 shadow-sm rounded-4 mb-2">
        <div class="card-body">
          <div class="d-flex align-items-center gap-3">
            <span class="tile-icon ti-<%= tints[i] %>" style="width:44px;height:44px;font-size:1.1rem"><i data-lucide="users"></i></span>
            <div class="flex-grow-1">
              <div class="fw-bold d-flex align-items-center gap-2">
                <%= t('ref_tier', { n: i + 1 }) %>
                <span class="badge bg-success-subtle text-success"><%= tier.percent %>%</span>
              </div>
              <div class="small text-muted"><%= t('ref_tier_' + (i + 1) + '_d') %></div>
            </div>
            <div class="text-end">
              <div class="h5 fw-bold mb-0"><%= tier.members.length %></div>
              <div class="small text-muted"><%= t('ref_members') %></div>
            </div>
          </div>

          <% if (tier.members.length) { %>
            <div class="d-flex flex-wrap gap-2 mt-3 pt-3 border-top">
              <% tier.members.forEach(m => { %>
                <span class="badge bg-body-secondary text-body d-inline-flex align-items-center gap-1 p-2">
                  <% if (m.avatar) { %>
                    <img src="<%= m.avatar %>" class="rounded-circle" style="width:20px;height:20px;object-fit:cover" alt="">
                  <% } else { %>
                    <span class="rounded-circle bg-primary-subtle text-primary d-inline-flex align-items-center justify-content-center fw-bold"
                          style="width:20px;height:20px;font-size:.65rem"><%= m.name.charAt(0).toUpperCase() %></span>
                  <% } %>
                  <%= m.name %>
                  <% if (!m.active) { %><i data-lucide="hourglass" class="text-muted"></i><% } %>
                </span>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    <% }) %>

    <div class="alert alert-secondary small mt-3 d-flex align-items-center gap-2">
      <i data-lucide="info"></i><span><%= t('ref_note') %></span>
    </div>
  </div>
</section>
