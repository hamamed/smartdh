<section class="py-5">
  <div class="container" style="max-width: 460px;">
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-4 p-md-5">
        <% if (sent) { %>
          <div class="text-center">
            <div class="tile-icon ti-mint mx-auto mb-3" style="width:72px;height:72px;font-size:1.9rem"><i data-lucide="mail-check"></i></div>
            <h4 class="fw-bold mb-2"><%= t('forgot_sent_t') %></h4>
            <p class="text-muted mb-4"><%= t('forgot_sent_d') %></p>
            <a href="/login" class="btn btn-primary d-inline-flex align-items-center gap-1"><i data-lucide="log-in"></i><%= t('btn_login') %></a>
          </div>
        <% } else { %>
          <h3 class="fw-bold mb-1"><%= t('forgot_title') %></h3>
          <p class="text-muted mb-4"><%= t('forgot_sub') %></p>
          <form method="post" action="/forgot"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="mb-3">
              <label class="form-label"><%= t('lbl_email') %></label>
              <input name="email" type="email" class="form-control" required>
            </div>
            <button class="btn btn-primary w-100 py-2 d-inline-flex align-items-center justify-content-center gap-1">
              <i data-lucide="mail"></i><%= t('forgot_send') %>
            </button>
          </form>
          <p class="text-center text-muted small mt-4 mb-0"><a href="/login"><%= t('btn_login') %></a></p>
        <% } %>
      </div>
    </div>
  </div>
</section>
