<section class="py-5">
  <div class="container" style="max-width: 460px;">
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-4 p-md-5">
        <h3 class="fw-bold mb-1"><%= t('login_title') %></h3>
        <p class="text-muted mb-4"><%= t('login_sub') %></p>

        <% if (typeof notice !== 'undefined' && notice) { %>
          <div class="alert alert-success py-2 d-flex align-items-center gap-1"><i data-lucide="check"></i><%= notice %></div>
        <% } %>
        <% if (error) { %>
          <div class="alert alert-danger py-2"><i data-lucide="alert-triangle" class="me-1"></i><%= error %></div>
        <% } %>
        <% if (typeof unverified !== 'undefined' && unverified) { %>
          <form method="post" action="/resend-verification" class="mb-3">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="email" value="<%= unverified %>">
            <button class="btn btn-outline-primary btn-sm w-100 d-inline-flex align-items-center justify-content-center gap-1"><i data-lucide="mail"></i><%= t('login_resend') %></button>
          </form>
        <% } %>

        <form method="post" action="/login"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="mb-3">
            <label class="form-label"><%= t('lbl_email') %></label>
            <input name="email" type="email" class="form-control" value="<%= form.email || '' %>" required>
          </div>
          <div class="mb-3">
            <label class="form-label"><%= t('lbl_password') %></label>
            <input name="password" type="password" class="form-control" required>
          </div>
          <button class="btn btn-primary w-100 py-2"><i data-lucide="log-in" class="me-1"></i><%= t('btn_login') %></button>
        </form>

        <p class="text-center small mt-3 mb-0"><a href="/forgot" class="text-muted"><%= t('forgot_link') %></a></p>
        <p class="text-center text-muted small mt-3 mb-0">
          <%= t('new_here') %> <a href="/signup"><%= t('link_signup') %></a>
        </p>
      </div>
    </div>
  </div>
</section>
