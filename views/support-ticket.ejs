<section class="py-4 py-lg-5">
  <div class="container" style="max-width: 620px;">
    <% const sc = ticket.status==='closed'?'secondary':(ticket.status==='answered'?'success':'warning'); %>
    <div class="d-flex align-items-center gap-2 mb-2">
      <a href="/support" class="btn btn-outline-secondary btn-icon rounded-circle"><i data-lucide="arrow-left"></i></a>
      <h3 class="fw-bold mb-0 flex-grow-1 min-w-0 text-truncate">#<%= ticket.id %> · <%= ticket.subject %></h3>
      <span class="badge bg-<%= sc %>-subtle text-<%= sc %> flex-shrink-0"><%= t('sup_status_' + ticket.status) %></span>
    </div>
    <p class="text-muted small mb-4"><%= t('sup_t_' + ticket.topic) %></p>

    <div class="card border-0 shadow-sm rounded-4 mb-3">
      <div class="card-body d-flex flex-column gap-3">
        <% ticket.messages.forEach(msg => { const mine = msg.from === 'user'; %>
          <div class="d-flex <%= mine ? 'justify-content-end' : 'justify-content-start' %>">
            <div class="p-3 rounded-4 <%= mine ? 'bg-primary-subtle' : 'bg-body-secondary' %>" style="max-width:85%">
              <div class="small fw-semibold mb-1 d-flex align-items-center gap-1">
                <i data-lucide="<%= mine ? 'user' : 'life-buoy' %>" style="width:.85em;height:.85em"></i>
                <%= mine ? t('sup_you') : t('sup_support') %>
                <span class="text-muted fw-normal" style="font-size:.72rem" title="<%= new Date(msg.at).toLocaleString() %>">· <span data-ago="<%= msg.at %>"><%= timeAgo(msg.at) %></span></span>
              </div>
              <div class="small" style="white-space:pre-wrap"><%= msg.text %></div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

    <% if (ticket.status === 'closed') { %>
      <p class="text-muted small text-center"><%= t('sup_closed_note') %></p>
      <div class="text-center"><a href="/support" class="btn btn-outline-primary btn-sm d-inline-flex align-items-center gap-1"><i data-lucide="plus"></i><%= t('sup_open_ticket') %></a></div>
    <% } else { %>
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body">
          <form method="post" action="/support/<%= ticket.id %>/reply"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <textarea name="message" class="form-control mb-2" rows="3" maxlength="4000" placeholder="<%= t('sup_reply_ph') %>" required></textarea>
            <button class="btn btn-primary d-inline-flex align-items-center gap-1"><i data-lucide="send"></i><%= t('sup_reply') %></button>
          </form>
        </div>
      </div>
    <% } %>
  </div>
</section>
