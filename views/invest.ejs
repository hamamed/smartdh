<section class="py-4 py-lg-5">
  <div class="container">
    <div class="d-flex align-items-center gap-2 mb-4">
      <a href="/dashboard" class="btn btn-outline-secondary btn-icon rounded-circle"><i data-lucide="arrow-left"></i></a>
      <h3 class="fw-bold mb-0"><%= t('plans_title') %></h3>
    </div>

    <div id="flash"></div>

    <!-- How to deposit -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
      <div class="card-body">
        <h6 class="fw-bold mb-2 d-flex align-items-center gap-2"><i data-lucide="landmark" class="text-primary"></i><%= t('deposit_how_title') %></h6>
        <p class="text-muted small mb-3"><%= t('deposit_how_desc') %></p>
        <div class="row g-3 align-items-center">
          <div class="col-md-8">
            <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted small"><%= t('deposit_bank') %></span><span class="fw-semibold"><%= depositInfo.bankName %></span></div>
            <div class="d-flex justify-content-between align-items-center border-bottom py-1 gap-2">
              <span class="text-muted small"><%= t('deposit_account') %></span>
              <span class="fw-semibold d-inline-flex align-items-center gap-1"><%= depositInfo.accountName %>
                <button type="button" class="btn btn-link btn-icon p-0 text-muted" style="width:1.4em;height:1.4em" data-copy="<%= depositInfo.accountName %>" title="<%= t('btn_copy') %>" aria-label="<%= t('btn_copy') %>"><i data-lucide="copy" style="width:.9em;height:.9em"></i></button>
              </span>
            </div>
            <div class="d-flex justify-content-between align-items-center border-bottom py-1 gap-2">
              <span class="text-muted small"><%= t('deposit_rib') %></span>
              <span class="fw-semibold d-inline-flex align-items-center gap-1" dir="ltr"><%= depositInfo.rib %>
                <button type="button" class="btn btn-link btn-icon p-0 text-muted" style="width:1.4em;height:1.4em" data-copy="<%= depositInfo.rib %>" title="<%= t('btn_copy') %>" aria-label="<%= t('btn_copy') %>"><i data-lucide="copy" style="width:.9em;height:.9em"></i></button>
              </span>
            </div>
          </div>
          <div class="col-md-4 text-center">
            <% if (depositQR) { %>
              <img src="<%= depositQR %>" alt="QR" class="img-fluid rounded-3 border" style="max-width:180px">
              <div class="small text-muted mt-1 d-flex align-items-center justify-content-center gap-1"><i data-lucide="qr-code"></i><%= t('deposit_scan') %></div>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- Apps -->
    <div class="row g-3 mb-4">
      <% plans.forEach(p => { const held = (currentUser.invested && currentUser.invested[p.id]) || 0;
           const locked = level < (p.minLevel || 1);
           const earn30 = held * (p.ratePer15Days || 0) * 2; // 30 days = two 15-day cycles %>
        <div class="col-md-4">
          <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden product-card <%= locked ? 'opacity-75' : '' %>">
            <div class="product-media">
              <% if (p.imageUrl) { %>
                <img src="<%= p.imageUrl %>" alt="<%= planName(p) %>">
              <% } else { %>
                <div class="product-media-fallback ti-<%= p.color==='primary'?'navy':(p.color==='success'?'mint':(p.color==='danger'?'coral':(p.color==='warning'?'yellow':(p.color==='info'?'sky':'lilac')))) %>"><i data-lucide="<%= p.icon %>"></i></div>
              <% } %>
              <span class="badge bg-<%= p.color %> position-absolute top-0 end-0 m-2"><%= (p.ratePer15Days*100).toFixed(1) %>% <%= t('per15_suffix') %></span>
              <% if (locked) { %><span class="badge bg-dark position-absolute top-0 start-0 m-2 d-inline-flex align-items-center gap-1"><i data-lucide="lock"></i><%= t('level_label') %> <%= p.minLevel %></span><% } %>
            </div>
            <div class="card-body">
              <h6 class="fw-bold mb-1"><%= planName(p) %></h6>
              <p class="text-muted small mb-2"><%= planDesc(p) %></p>
              <div class="d-flex justify-content-between align-items-end gap-2 mb-3 p-2 rounded-3 bg-body-secondary">
                <div>
                  <div class="small text-muted"><%= t('plan_youhave') %></div>
                  <div class="fw-bold"><%= money(held) %></div>
                </div>
                <div class="text-end">
                  <div class="small text-muted d-flex align-items-center gap-1 justify-content-end"><i data-lucide="trending-up"></i><%= t('earn_30d') %></div>
                  <div class="fw-bold text-success"><%= held > 0 ? '+' : '' %><%= money(earn30) %></div>
                </div>
              </div>
              <% if (locked) { %>
                <div class="alert alert-secondary py-2 small mb-0 text-center d-flex align-items-center justify-content-center gap-1">
                  <i data-lucide="lock"></i><%= t('locked_at', { n: p.minLevel }) %>
                </div>
              <% } else { %>
                <form action="/add-funds" method="post"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="plan" value="<%= p.id %>">
                  <div class="d-flex gap-1">
                    <input name="amount" type="number" min="<%= settings.minAddFunds %>" step="1"
                           class="form-control form-control-sm" placeholder="<%= t('amount_ph') %>"
                           data-earn-input data-rate="<%= p.ratePer15Days %>">
                    <button class="btn btn-sm btn-<%= p.color %>"><i data-lucide="plus"></i></button>
                  </div>
                  <div class="small text-success mt-1 d-none d-flex align-items-center gap-1" data-earn-out>
                    <i data-lucide="trending-up"></i><span></span>
                  </div>
                </form>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- Your deposits -->
    <% if (myDeposits && myDeposits.length) { %>
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body">
          <h6 class="fw-bold mb-3 d-flex align-items-center gap-2"><i data-lucide="receipt" class="text-primary"></i><%= t('deposit_pending_title') %></h6>
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <tbody>
                <% myDeposits.forEach(d => { const dc = d.status==='approved'?'success':(d.status==='rejected'?'danger':'warning'); %>
                  <tr>
                    <td class="fw-semibold"><%= money(d.amount) %></td>
                    <td class="small"><%= d.planLabel %></td>
                    <td><span class="badge bg-<%= dc %>-subtle text-<%= dc %>"><%= statusLabel(d.status) %></span></td>
                    <td class="small text-muted text-end"><span data-ago="<%= d.createdAt %>" title="<%= new Date(d.createdAt).toLocaleString() %>"><%= timeAgo(d.createdAt) %></span></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</section>
