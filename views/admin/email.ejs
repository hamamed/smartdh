<section class="py-4 py-lg-5">
  <div class="container" style="max-width: 720px;">
    <%- include('_head', { heading: t('tab_email'), back: '/admin' }) %>

    <% if (sent !== null) { %>
      <div class="alert alert-success py-2 d-flex align-items-center gap-2">
        <i data-lucide="mail-check"></i>
        <span><%= t('email_sent_n', { n: sent }) %><% if (skipped) { %> · <%= t('email_skipped_n', { n: skipped }) %><% } %></span>
      </div>
    <% } %>
    <% if (err === 'empty') { %>
      <div class="alert alert-danger py-2 d-flex align-items-center gap-1"><i data-lucide="alert-triangle"></i><%= t('email_err_empty') %></div>
    <% } %>

    <p class="text-muted small mb-3"><%= t('email_intro') %></p>

    <form action="/admin/email/send" method="post" id="emailForm">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <!-- Audience -->
      <div class="card border-0 shadow-sm rounded-4 mb-3">
        <div class="card-body">
          <label class="form-label fw-semibold"><%= t('email_audience') %></label>
          <div class="row g-2">
            <div class="col-sm-4">
              <input type="radio" class="btn-check" name="audience" id="aud-active" value="active" checked>
              <label class="btn btn-outline-primary w-100 d-flex flex-column py-2" for="aud-active">
                <span class="fw-semibold"><%= t('email_aud_active') %></span>
                <span class="small text-muted"><%= audienceCounts.active %></span>
              </label>
            </div>
            <div class="col-sm-4">
              <input type="radio" class="btn-check" name="audience" id="aud-pending" value="pending">
              <label class="btn btn-outline-primary w-100 d-flex flex-column py-2" for="aud-pending">
                <span class="fw-semibold"><%= t('email_aud_pending') %></span>
                <span class="small text-muted"><%= audienceCounts.pending %></span>
              </label>
            </div>
            <div class="col-sm-4">
              <input type="radio" class="btn-check" name="audience" id="aud-all" value="all">
              <label class="btn btn-outline-primary w-100 d-flex flex-column py-2" for="aud-all">
                <span class="fw-semibold"><%= t('email_aud_all') %></span>
                <span class="small text-muted"><%= audienceCounts.all %></span>
              </label>
            </div>
          </div>

          <div class="mt-3">
            <label class="form-label small"><%= t('email_specific') %></label>
            <input name="specific" class="form-control" placeholder="<%= t('email_specific_ph') %>">
            <div class="form-text"><%= t('email_specific_d') %></div>
          </div>

          <% if (optedOut) { %>
            <div class="small text-muted mt-2 d-flex align-items-center gap-1">
              <i data-lucide="mail-x"></i><%= t('email_optout_note', { n: optedOut }) %>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Message -->
      <div class="card border-0 shadow-sm rounded-4 mb-3">
        <div class="card-body">
          <div class="mb-3">
            <label class="form-label fw-semibold"><%= t('email_subject') %></label>
            <input name="subject" class="form-control" maxlength="140" required
                   placeholder="<%= t('email_subject_ph') %>">
          </div>
          <div class="mb-3">
            <label class="form-label"><%= t('email_heading') %> <span class="text-muted small"><%= t('opt') %></span></label>
            <input name="heading" class="form-control" maxlength="140"
                   placeholder="<%= t('email_heading_ph') %>">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold"><%= t('email_message') %></label>
            <textarea name="message" class="form-control" rows="7" required
                      placeholder="<%= t('email_message_ph') %>"></textarea>
            <div class="form-text"><%= t('email_message_d') %></div>
          </div>
          <div class="row g-2">
            <div class="col-sm-6">
              <label class="form-label small"><%= t('email_cta_text') %></label>
              <input name="ctaText" class="form-control" maxlength="60" placeholder="<%= t('email_cta_text_ph') %>">
            </div>
            <div class="col-sm-6">
              <label class="form-label small"><%= t('email_cta_url') %></label>
              <input name="ctaUrl" type="url" class="form-control" placeholder="https://smartdh.ma/dashboard">
            </div>
          </div>
        </div>
      </div>

      <div class="d-flex flex-wrap gap-2 align-items-center">
        <button class="btn btn-primary d-inline-flex align-items-center gap-2" type="submit">
          <i data-lucide="send"></i><%= t('email_send_btn') %>
        </button>
        <button class="btn btn-outline-secondary d-inline-flex align-items-center gap-2" type="submit"
                name="testOnly" value="1" formnovalidate
                onclick="return this.form.subject.value && this.form.message.value;">
          <i data-lucide="flask-conical"></i><%= t('email_test_btn', { email: adminEmail }) %>
        </button>
      </div>
      <p class="small text-muted mt-3 mb-0 d-flex align-items-start gap-1">
        <i data-lucide="info"></i><span><%= t('email_footer_note') %></span>
      </p>
    </form>
  </div>
</section>
