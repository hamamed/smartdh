<section class="py-4 py-lg-5">
  <div class="container">
    <%- include('_head', { heading: t('tab_audit') }) %>

    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body">
        <div class="d-flex justify-content-end gap-2 mb-3">
          <a href="/admin/export/users.csv" class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1"><i data-lucide="download"></i><%= t('export_users') %></a>
          <a href="/admin/export/deposits.csv" class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1"><i data-lucide="download"></i><%= t('export_deposits') %></a>
          <a href="/admin/export/withdrawals.csv" class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1"><i data-lucide="download"></i><%= t('export_withdrawals') %></a>
        </div>
        <% if (audit.length === 0) { %>
          <p class="text-muted mb-0"><%= t('audit_none') %></p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead class="text-muted small"><tr><th><%= t('th_when') %></th><th><%= t('audit_who') %></th><th><%= t('audit_action') %></th><th><%= t('th_details') %></th></tr></thead>
              <tbody>
                <% audit.forEach(a => { %>
                  <tr>
                    <td class="small text-muted text-nowrap"><%= new Date(a.at).toLocaleString() %></td>
                    <td class="small fw-semibold"><%= a.adminName %></td>
                    <td><span class="badge bg-primary-subtle text-primary"><%= a.action %></span></td>
                    <td class="small"><%= a.details %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>
