<section class="py-4 py-lg-5">
  <div class="container">
    <%- include('_head', { heading: t('tab_withdrawals') }) %>

    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body">
        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
          <form method="get" action="/admin/withdrawals" class="d-flex gap-2" style="max-width:320px">
            <% if (per !== 10) { %><input type="hidden" name="per" value="<%= per %>"><% } %>
            <% if (status) { %><input type="hidden" name="status" value="<%= status %>"><% } %>
            <div class="input-group input-group-sm">
              <span class="input-group-text"><i data-lucide="search"></i></span>
              <input name="q" class="form-control" placeholder="<%= t('search_player') %>" value="<%= q %>">
            </div>
            <button class="btn btn-sm btn-primary"><%= t('btn_search') %></button>
          </form>
          <div class="ms-auto d-flex gap-2 flex-wrap align-items-center">
            <%- include('_filters', {
                  keep: (per !== 10 ? '&per=' + per : ''), base: '/admin/withdrawals', current: status, q: q,
                  options: [
                    { value: '',         label: t('filter_all'),  count: (statusCounts.pending||0)+(statusCounts.paid||0)+(statusCounts.rejected||0) },
                    { value: 'pending',  label: t('st_pending'),  count: statusCounts.pending  || 0, danger: true },
                    { value: 'paid',     label: t('st_paid'),     count: statusCounts.paid     || 0 },
                    { value: 'rejected', label: t('st_rejected'), count: statusCounts.rejected || 0 }
                  ]
                }) %>
            <a href="/admin/export/withdrawals.csv" class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1"><i data-lucide="download"></i><%= t('export_withdrawals') %></a>
          </div>
        </div>
        <% if (withdrawals.length === 0) { %>
          <p class="text-muted mb-0"><%= t('no_results') %></p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table align-middle mb-0">
              <thead class="text-muted small"><tr><th><%= t('th_user') %></th><th><%= t('th_amount') %></th><th><%= t('th_from') %></th><th><%= t('th_method') %></th><th><%= t('th_details') %></th><th><%= t('th_status') %></th><th class="text-end"><%= t('th_action') %></th></tr></thead>
              <tbody>
                <% withdrawals.forEach(w => { const wc = w.status==='paid'?'success':(w.status==='rejected'?'danger':'warning'); %>
                  <tr>
                    <td><a href="/admin/users/<%= w.userId %>" class="fw-semibold"><%= w.userName %></a></td>
                    <td class="fw-semibold"><%= money(w.amount) %></td>
                    <td class="small"><%= w.fromLabel || w.from %></td>
                    <td class="small"><%= w.method === 'bank' ? t('payout_bank') : (w.method === 'paypal' ? t('payout_paypal') : '—') %></td>
                    <td class="small" style="max-width:200px;word-break:break-word">
                      <% if (w.payoutName || w.payoutAccount) { %>
                        <div class="fw-semibold"><%= w.payoutName || '—' %></div>
                        <div class="text-muted" dir="ltr"><%= w.payoutAccount || '—' %></div>
                      <% } else { %><%= w.details || '—' %><% } %>
                    </td>
                    <td><span class="badge bg-<%= wc %>-subtle text-<%= wc %> text-capitalize"><%= w.status %></span></td>
                    <td class="text-end text-nowrap">
                      <% if (w.status === 'pending') { %>
                        <form action="/admin/withdraw/<%= w.id %>/approve" method="post" class="d-inline"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button class="btn btn-sm btn-success"><i data-lucide="check" class="me-1"></i><%= t('btn_markpaid') %></button></form>
                        <form action="/admin/withdraw/<%= w.id %>/reject" method="post" class="d-inline"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button class="btn btn-sm btn-outline-danger"><i data-lucide="x"></i></button></form>
                      <% } else { %><span class="text-muted small">—</span><% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% const kept = (status ? '&status=' + status : '') + (q ? '&q=' + encodeURIComponent(q) : ''); %>
          <div class="d-flex flex-wrap justify-content-between align-items-center mt-3 gap-2">
            <span class="small text-muted"><%= t('showing_n', { shown: withdrawals.length, total: total }) %></span>
            <%- include('_perpage', { base: '/admin/withdrawals', per: per, options: perOptions, qs: kept }) %>
            <%- include('_pager', { base: '/admin/withdrawals', page: page, pages: pages, qs: kept + '&per=' + per }) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>
