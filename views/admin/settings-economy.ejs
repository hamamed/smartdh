<section class="py-4 py-lg-5">
  <div class="container" style="max-width: 680px;">
    <%- include('_head', { heading: t('set_economy_t'), back: '/admin/settings' }) %>
    <% if (ok) { %><div class="alert alert-success py-2 d-flex align-items-center gap-1"><i data-lucide="check"></i><%= t('profile_saved') %></div><% } %>

    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body">
        <p class="text-muted small mb-3"><%= t('set_economy_d') %></p>
        <form action="/admin/settings/economy" method="post"><input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <h6 class="fw-bold small text-uppercase text-muted mb-2"><%= t('set_limits') %></h6>
          <div class="row g-3 mb-4">
            <div class="col-md-4">
              <label class="form-label"><%= t('set_minadd') %></label>
              <div class="input-group"><input name="minAddFunds" type="number" min="0" class="form-control" value="<%= settings.minAddFunds %>">
                <span class="input-group-text"><%= curLabel %></span></div>
            </div>
            <div class="col-md-4">
              <label class="form-label"><%= t('set_minwd') %></label>
              <div class="input-group"><input name="minWithdraw" type="number" min="0" class="form-control" value="<%= settings.minWithdraw %>">
                <span class="input-group-text"><%= curLabel %></span></div>
            </div>
            <div class="col-md-4">
              <label class="form-label"><%= t('set_mintransfer') %></label>
              <div class="input-group"><input name="minTransfer" type="number" min="0" class="form-control" value="<%= settings.minTransfer %>">
                <span class="input-group-text"><%= curLabel %></span></div>
            </div>
            <div class="col-md-4">
              <label class="form-label"><%= t('set_wdevery') %></label>
              <input name="withdrawEveryDays" type="number" min="0" class="form-control" value="<%= settings.withdrawEveryDays %>">
            </div>
            <div class="col-md-4">
              <label class="form-label"><%= t('set_lockdays') %></label>
              <div class="input-group">
                <input name="depositLockDays" type="number" min="0" class="form-control" value="<%= settings.depositLockDays %>">
                <span class="input-group-text"><%= t('days_unit') %></span>
              </div>
              <div class="form-text"><%= t('set_lockdays_hint') %></div>
            </div>
          </div>

          <h6 class="fw-bold small text-uppercase text-muted mb-2"><%= t('set_tiers') %></h6>
          <div class="row g-3 mb-2">
            <% [1, 2, 3].forEach(n => { %>
              <div class="col-md-4">
                <label class="form-label"><%= t('ref_tier', { n: n }) %></label>
                <div class="input-group">
                  <input name="tier<%= n %>" type="number" step="0.05" min="0" class="form-control"
                         value="<%= (settings.referralTiers[n-1] * 100) %>">
                  <span class="input-group-text">%</span>
                </div>
              </div>
            <% }) %>
          </div>
          <div class="form-text mb-4"><%= t('set_tiers_hint') %></div>

          <h6 class="fw-bold small text-uppercase text-muted mb-2"><%= t('set_rewards') %></h6>
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label class="form-label"><%= t('set_dailybase') %></label>
              <div class="input-group"><input name="dailyBonusBase" type="number" min="0" class="form-control" value="<%= settings.dailyBonusBase %>">
                <span class="input-group-text"><%= curLabel %></span></div>
              <div class="form-text"><%= t('set_dailybase_hint', { max: money(settings.dailyBonusBase * 7) }) %></div>
            </div>
          </div>

          <button class="btn btn-primary d-inline-flex align-items-center gap-1"><i data-lucide="save"></i><%= t('btn_save') %></button>
        </form>
      </div>
    </div>

    <div class="alert alert-secondary small mt-3 d-flex align-items-center gap-2">
      <i data-lucide="info"></i><span><%= t('set_rates_note') %> <a href="/admin/apps"><%= t('tab_apps') %></a>.</span>
    </div>
  </div>
</section>
