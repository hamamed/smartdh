<section class="py-4 py-lg-5">
  <div class="container" style="max-width: 720px;">
    <%- include('_head', { heading: '#' + ticket.id + ' · ' + ticket.subject, back: '/admin/tickets' }) %>

    <% const sc = ticket.status==='closed'?'secondary':(ticket.status==='answered'?'success':'warning'); %>
    <!-- meta -->
    <div class="card border-0 shadow-sm rounded-4 mb-3">
      <div class="card-body d-flex flex-wrap align-items-center gap-2 small">
        <span class="badge bg-<%= sc %>-subtle text-<%= sc %>"><%= t('sup_status_' + ticket.status) %></span>
        <span class="text-muted"><%= t('sup_topic') %>: <span class="fw-semibold text-body"><%= t('sup_t_' + ticket.topic) %></span></span>
        <span class="text-muted">· <%= t('sup_created') %> <span data-ago="<%= ticket.createdAt %>" title="<%= new Date(ticket.createdAt).toLocaleString() %>"><%= timeAgo(ticket.createdAt) %></span></span>
        <div class="ms-auto d-flex align-items-center gap-2">
          <span class="fw-semibold"><%= ticket.userName %></span>
          <span class="text-muted"><%= ticket.email %></span>
          <% if (tuser) { %><a href="/admin/users/<%= tuser.id %>" class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1"><i data-lucide="user"></i><%= t('btn_manage') %></a><% } %>
        </div>
      </div>
    </div>

    <!-- thread -->
    <div class="card border-0 shadow-sm rounded-4 mb-3">
      <div class="card-body d-flex flex-column gap-3">
        <% ticket.messages.forEach(msg => { const admin = msg.from === 'admin'; %>
          <div class="d-flex <%= admin ? 'justify-content-end' : 'justify-content-start' %>">
            <div class="p-3 rounded-4 <%= admin ? 'bg-primary-subtle' : 'bg-body-secondary' %>" style="max-width:85%">
              <div class="small fw-semibold mb-1 d-flex align-items-center gap-1">
                <i data-lucide="<%= admin ? 'life-buoy' : 'user' %>" style="width:.85em;height:.85em"></i>
                <%= admin ? (msg.authorName || t('sup_support')) : ticket.userName %>
                <span class="text-muted fw-normal" style="font-size:.72rem" title="<%= new Date(msg.at).toLocaleString() %>">· <span data-ago="<%= msg.at %>"><%= timeAgo(msg.at) %></span></span>
              </div>
              <% if (msg.text) { %><div class="small" style="white-space:pre-wrap"><%= msg.text %></div><% } %>
              <% if (msg.file) { %>
                <% if ((msg.fileType||'').startsWith('image/')) { %>
                  <a href="<%= msg.file %>" target="_blank" rel="noopener" class="d-inline-block mt-2"><img src="<%= msg.file %>" alt="<%= msg.fileName %>" style="max-width:240px;max-height:240px;border-radius:10px;border:1px solid var(--line)"></a>
                <% } else { %>
                  <a href="<%= msg.file %>" target="_blank" rel="noopener" download class="d-inline-flex align-items-center gap-1 mt-2 small fw-semibold text-primary text-decoration-none"><i data-lucide="paperclip"></i><%= msg.fileName || t('sup_attachment') %></a>
                <% } %>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

    <!-- reply -->
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body">
        <form method="post" action="/admin/tickets/<%= ticket.id %>/reply?_csrf=<%= csrfToken %>" enctype="multipart/form-data"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <textarea name="message" class="form-control mb-2" rows="4" maxlength="4000" placeholder="<%= t('sup_reply_ph') %>"></textarea>
          <div class="mb-2">
            <label class="form-label small d-flex align-items-center gap-1"><i data-lucide="paperclip"></i><%= t('sup_attach') %></label>
            <input name="file" type="file" accept="image/*,application/pdf,.doc,.docx,.txt" class="form-control form-control-sm" data-preview="#admReplyPrev">
            <div id="admReplyPrev"></div>
          </div>
          <div class="d-flex flex-wrap gap-2 align-items-center">
            <button class="btn btn-primary d-inline-flex align-items-center gap-1"><i data-lucide="send"></i><%= t('sup_reply') %></button>
            <button name="close" value="1" class="btn btn-outline-secondary d-inline-flex align-items-center gap-1"><i data-lucide="check-check"></i><%= t('sup_reply') %> + <%= t('sup_status_closed') %></button>
          </div>
        </form>
        <% if (ticket.status !== 'closed') { %>
          <form method="post" action="/admin/tickets/<%= ticket.id %>/close" class="mt-2">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="btn btn-sm btn-link text-muted p-0"><%= t('sup_status_closed') %></button>
          </form>
        <% } %>
      </div>
    </div>
  </div>
</section>
