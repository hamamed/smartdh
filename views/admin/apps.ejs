<section class="py-4 py-lg-5">
  <div class="container">
    <%- include('_head', { heading: t('tab_apps') }) %>

    <div class="card border-0 shadow-sm rounded-4 mb-3">
      <div class="card-body">
        <% if (plans.length === 0) { %>
          <p class="text-muted mb-0"><%= t('apps_none') %></p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table align-middle mb-0">
              <thead class="text-muted small"><tr><th><%= t('th_app') %></th><th><%= t('th_rate') %> · <%= t('th_level') %></th><th class="text-end"></th></tr></thead>
              <tbody>
                <% plans.forEach(p => { %>
                  <tr>
                    <td>
                      <div class="d-flex align-items-center gap-2">
                        <% if (p.imageUrl) { %><img src="<%= p.imageUrl %>" style="width:34px;height:34px;object-fit:cover" class="rounded-3">
                        <% } else { %><span class="tile-icon ti-<%= p.color==='primary'?'navy':(p.color==='success'?'mint':(p.color==='danger'?'coral':(p.color==='warning'?'yellow':(p.color==='info'?'sky':'lilac')))) %>" style="width:34px;height:34px;font-size:1rem"><i data-lucide="<%= p.icon %>"></i></span><% } %>
                        <div>
                          <div class="fw-semibold"><%= p.name %></div>
                          <div class="small text-muted"><%= p.desc %></div>
                        </div>
                      </div>
                    </td>
                    <td>
                      <form action="/admin/apps/edit/<%= p.id %>" method="post" class="d-flex flex-wrap gap-1 align-items-center"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input name="name" class="form-control form-control-sm" style="max-width:130px" value="<%= p.name %>">
                        <div class="input-group input-group-sm" style="max-width:100px">
                          <input name="rate" type="number" step="0.1" class="form-control" value="<%= (p.ratePer15Days*100).toFixed(1) %>">
                          <span class="input-group-text">%</span>
                        </div>
                        <input name="minLevel" type="number" min="1" class="form-control form-control-sm" style="max-width:64px" title="<%= t('app_minlevel') %>" value="<%= p.minLevel || 1 %>">
                        <input name="icon" class="form-control form-control-sm" style="max-width:110px" title="<%= t('app_icon') %>" value="<%= p.icon %>">
                        <button class="btn btn-sm btn-outline-primary"><i data-lucide="save"></i></button>
                      </form>
                    </td>
                    <td class="text-end">
                      <form action="/admin/apps/delete/<%= p.id %>" method="post" onsubmit="return confirm('<%= t('confirm_delete_app') %>')"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button class="btn btn-sm btn-outline-danger"><i data-lucide="trash-2"></i></button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <p class="form-text mb-0"><%= t('app_delete_hint') %></p>
        <% } %>
      </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body">
        <h6 class="fw-bold mb-3 d-flex align-items-center gap-2"><i data-lucide="plus" class="text-primary"></i><%= t('add_app_title') %></h6>
        <form action="/admin/apps/add" method="post" class="row g-2"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="col-md-6"><label class="form-label small"><%= t('app_name') %></label><input name="name" class="form-control" required></div>
          <div class="col-md-3"><label class="form-label small"><%= t('app_icon') %></label><input name="icon" class="form-control" placeholder="rocket" value="trending-up"></div>
          <div class="col-md-3"><label class="form-label small"><%= t('app_rate') %></label><input name="rate" type="number" step="0.1" class="form-control" value="10"></div>
          <div class="col-md-6"><label class="form-label small"><%= t('app_image') %></label><input name="imageUrl" class="form-control" placeholder="https://…"></div>
          <div class="col-md-3"><label class="form-label small"><%= t('app_minlevel') %></label><input name="minLevel" type="number" min="1" class="form-control" value="1"></div>
          <div class="col-md-3"><label class="form-label small"><%= t('app_color') %></label>
            <select name="color" class="form-select">
              <option value="primary">primary</option><option value="success">success</option>
              <option value="danger">danger</option><option value="warning">warning</option>
              <option value="info">info</option><option value="secondary">secondary</option>
            </select></div>
          <div class="col-12"><label class="form-label small"><%= t('app_desc') %></label><input name="desc" class="form-control"></div>
          <div class="col-12"><button class="btn btn-primary d-inline-flex align-items-center gap-1"><i data-lucide="plus"></i><%= t('btn_addapp') %></button></div>
        </form>
        <p class="form-text mb-0 mt-2"><%= t('app_icon_hint') %></p>
      </div>
    </div>
  </div>
</section>
