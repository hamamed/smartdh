<section class="py-4 py-lg-5">
  <div class="container">
    <%- include('_head', { heading: t('tab_apps') }) %>

    <!-- existing apps as editable product cards -->
    <% if (plans.length === 0) { %>
      <div class="card border-0 shadow-sm rounded-4 mb-3"><div class="card-body"><p class="text-muted mb-0"><%= t('apps_none') %></p></div></div>
    <% } else { %>
      <div class="row g-3 mb-4">
        <% plans.forEach(p => {
             const tint = p.color==='primary'?'navy':(p.color==='success'?'mint':(p.color==='danger'?'coral':(p.color==='warning'?'yellow':(p.color==='info'?'sky':'lilac')))); %>
          <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
              <div class="product-media">
                <% if (p.imageUrl) { %><img src="<%= p.imageUrl %>" alt="<%= p.name %>">
                <% } else { %><div class="product-media-fallback ti-<%= tint %>"><i data-lucide="<%= p.icon %>"></i></div><% } %>
              </div>
              <div class="card-body">
                <form action="/admin/apps/edit/<%= p.id %>?_csrf=<%= csrfToken %>" method="post" enctype="multipart/form-data">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <div class="mb-2"><label class="form-label small mb-1"><%= t('app_name') %></label>
                    <input name="name" class="form-control form-control-sm" value="<%= p.name %>"></div>
                  <div class="mb-2"><label class="form-label small mb-1"><%= t('app_desc') %></label>
                    <input name="desc" class="form-control form-control-sm" value="<%= p.desc %>"></div>
                  <div class="row g-2 mb-2">
                    <div class="col-6"><label class="form-label small mb-1"><%= t('app_rate') %></label>
                      <div class="input-group input-group-sm"><input name="rate" type="number" step="0.1" class="form-control" value="<%= (p.ratePer15Days*100).toFixed(1) %>"><span class="input-group-text">%</span></div></div>
                    <div class="col-6"><label class="form-label small mb-1"><%= t('app_minlevel') %></label>
                      <input name="minLevel" type="number" min="1" class="form-control form-control-sm" value="<%= p.minLevel || 1 %>"></div>
                    <div class="col-6"><label class="form-label small mb-1"><%= t('app_icon') %></label>
                      <input name="icon" class="form-control form-control-sm" value="<%= p.icon %>"></div>
                    <div class="col-6"><label class="form-label small mb-1"><%= t('app_color') %></label>
                      <select name="color" class="form-select form-select-sm">
                        <% ['primary','success','danger','warning','info','secondary'].forEach(c => { %><option value="<%= c %>" <%= p.color===c?'selected':'' %>><%= c %></option><% }) %>
                      </select></div>
                  </div>
                  <div class="mb-2"><label class="form-label small mb-1"><%= t('app_photo') %></label>
                    <input name="image" type="file" accept="image/*" class="form-control form-control-sm"></div>
                  <div class="mb-2"><label class="form-label small mb-1"><%= t('app_image_url') %></label>
                    <input name="imageUrl" type="url" class="form-control form-control-sm" placeholder="https://…" value="<%= /^https?:/.test(p.imageUrl || '') ? p.imageUrl : '' %>"></div>
                  <div class="mb-2"><label class="form-label small mb-1"><%= t('app_link') %></label>
                    <input name="link" type="url" class="form-control form-control-sm" placeholder="https://…" value="<%= p.link || '' %>">
                    <div class="form-text small"><%= t('app_link_hint') %></div></div>
                  <% if (p.imageUrl) { %>
                    <div class="form-check mb-2"><input class="form-check-input" type="checkbox" name="removeImage" value="1" id="rm<%= p.id %>">
                      <label class="form-check-label small" for="rm<%= p.id %>"><%= t('app_remove_photo') %></label></div>
                  <% } %>
                  <div class="d-flex gap-1">
                    <button class="btn btn-sm btn-primary flex-grow-1 d-inline-flex align-items-center justify-content-center gap-1"><i data-lucide="save"></i><%= t('btn_save') %></button>
                </form>
                    <form action="/admin/apps/delete/<%= p.id %>" method="post" onsubmit="return confirm('<%= t('confirm_delete_app') %>')"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button class="btn btn-sm btn-outline-danger"><i data-lucide="trash-2"></i></button></form>
                  </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
      <p class="form-text mb-4"><%= t('app_delete_hint') %></p>
    <% } %>

    <!-- add a new app / product -->
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body">
        <h6 class="fw-bold mb-3 d-flex align-items-center gap-2"><i data-lucide="plus" class="text-primary"></i><%= t('add_app_title') %></h6>
        <form action="/admin/apps/add?_csrf=<%= csrfToken %>" method="post" enctype="multipart/form-data" class="row g-2">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="col-md-6"><label class="form-label small"><%= t('app_name') %></label><input name="name" class="form-control" required></div>
          <div class="col-md-3"><label class="form-label small"><%= t('app_icon') %></label><input name="icon" class="form-control" placeholder="rocket" value="trending-up"></div>
          <div class="col-md-3"><label class="form-label small"><%= t('app_rate') %></label><input name="rate" type="number" step="0.1" class="form-control" value="10"></div>
          <div class="col-md-6"><label class="form-label small"><%= t('app_photo') %></label><input name="image" type="file" accept="image/*" class="form-control"></div>
          <div class="col-md-3"><label class="form-label small"><%= t('app_minlevel') %></label><input name="minLevel" type="number" min="1" class="form-control" value="1"></div>
          <div class="col-md-3"><label class="form-label small"><%= t('app_color') %></label>
            <select name="color" class="form-select">
              <% ['primary','success','danger','warning','info','secondary'].forEach(c => { %><option value="<%= c %>"><%= c %></option><% }) %>
            </select></div>
          <div class="col-md-6"><label class="form-label small"><%= t('app_image_url') %></label><input name="imageUrl" type="url" class="form-control" placeholder="https://…"><div class="form-text small"><%= t('app_image_url_hint') %></div></div>
          <div class="col-md-6"><label class="form-label small"><%= t('app_link') %></label><input name="link" type="url" class="form-control" placeholder="https://…"><div class="form-text small"><%= t('app_link_hint') %></div></div>
          <div class="col-12"><label class="form-label small"><%= t('app_desc') %></label><input name="desc" class="form-control"></div>
          <div class="col-12"><button class="btn btn-primary d-inline-flex align-items-center gap-1"><i data-lucide="plus"></i><%= t('btn_addapp') %></button></div>
        </form>
        <p class="form-text mb-0 mt-2"><%= t('app_photo_hint') %></p>
      </div>
    </div>
  </div>
</section>
