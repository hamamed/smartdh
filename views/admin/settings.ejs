<section class="py-4 py-lg-5">
  <div class="container" style="max-width: 720px;">
    <%- include('_head', { heading: t('tab_settings') }) %>
    <p class="text-muted mb-4"><%= t('settings_intro') %></p>

    <%
      const items = [
        { href: '/admin/settings/general',      icon: 'sliders-horizontal', tint: 'ti-sky',   title: t('set_general_t'),      desc: t('set_general_d') },
        { href: '/admin/settings/economy',      icon: 'coins',              tint: 'ti-mint',  title: t('set_economy_t'),      desc: t('set_economy_d') },
        { href: '/admin/settings/payments',     icon: 'landmark',           tint: 'ti-yellow',title: t('set_payments_t'),     desc: t('set_payments_d') },
        { href: '/admin/settings/announcement', icon: 'megaphone',          tint: 'ti-coral', title: t('set_announcement_t'), desc: t('set_announcement_d') },
        { href: '/admin/settings/campaign',     icon: 'party-popper',       tint: 'ti-lilac', title: t('set_campaign_t'),     desc: t('set_campaign_d') },
        { href: '/admin/apps',                  icon: 'layers',             tint: 'ti-navy',  title: t('tab_apps'),           desc: t('set_apps_d') },
        { href: '/admin/account',               icon: 'user-cog',           tint: 'ti-sky',   title: t('tab_account'),        desc: t('set_account_d') }
      ];
    %>
    <div class="d-grid gap-2">
      <% items.forEach(it => { %>
        <a href="<%= it.href %>" class="set-row d-flex align-items-center gap-3 p-3 text-reset">
          <span class="tile-icon <%= it.tint %> flex-shrink-0" style="width:44px;height:44px;font-size:1.2rem"><i data-lucide="<%= it.icon %>"></i></span>
          <span class="flex-grow-1 min-w-0">
            <span class="d-block fw-semibold"><%= it.title %></span>
            <span class="d-block small text-muted"><%= it.desc %></span>
          </span>
          <i data-lucide="chevron-right" class="text-muted flex-shrink-0"></i>
        </a>
      <% }) %>
    </div>
  </div>
</section>
