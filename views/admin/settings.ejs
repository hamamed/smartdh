<section class="py-4 py-lg-5">
  <div class="container">
    <%- include('_head', { heading: t('tab_settings') }) %>
    <p class="text-muted mb-4"><%= t('settings_intro') %></p>

    <div class="menu-grid">
      <a class="menu-tile" href="/admin/settings/general">
        <span class="tile-icon ti-sky"><i data-lucide="sliders-horizontal"></i></span>
        <span class="tile-label"><%= t('set_general_t') %></span>
      </a>
      <a class="menu-tile" href="/admin/settings/economy">
        <span class="tile-icon ti-mint"><i data-lucide="coins"></i></span>
        <span class="tile-label"><%= t('set_economy_t') %></span>
      </a>
      <a class="menu-tile" href="/admin/settings/payments">
        <span class="tile-icon ti-yellow"><i data-lucide="landmark"></i></span>
        <span class="tile-label"><%= t('set_payments_t') %></span>
      </a>
      <a class="menu-tile" href="/admin/settings/announcement">
        <span class="tile-icon ti-coral"><i data-lucide="megaphone"></i></span>
        <span class="tile-label"><%= t('set_announcement_t') %></span>
      </a>
      <a class="menu-tile" href="/admin/settings/campaign">
        <span class="tile-icon ti-mint"><i data-lucide="party-popper"></i></span>
        <span class="tile-label"><%= t("set_campaign_t") %></span>
      </a>
      <a class="menu-tile" href="/admin/apps">
        <span class="tile-icon ti-lilac"><i data-lucide="layers"></i></span>
        <span class="tile-label"><%= t('tab_apps') %></span>
      </a>
    </div>

    <div class="row g-3 mt-1">
      <div class="col-md-6"><div class="card border-0 shadow-sm rounded-4 h-100"><div class="card-body">
        <h6 class="fw-bold mb-1 d-flex align-items-center gap-2"><i data-lucide="sliders-horizontal" class="text-primary"></i><%= t('set_general_t') %></h6>
        <p class="text-muted small mb-0"><%= t('set_general_d') %></p>
      </div></div></div>
      <div class="col-md-6"><div class="card border-0 shadow-sm rounded-4 h-100"><div class="card-body">
        <h6 class="fw-bold mb-1 d-flex align-items-center gap-2"><i data-lucide="coins" class="text-primary"></i><%= t('set_economy_t') %></h6>
        <p class="text-muted small mb-0"><%= t('set_economy_d') %></p>
      </div></div></div>
      <div class="col-md-6"><div class="card border-0 shadow-sm rounded-4 h-100"><div class="card-body">
        <h6 class="fw-bold mb-1 d-flex align-items-center gap-2"><i data-lucide="landmark" class="text-primary"></i><%= t('set_payments_t') %></h6>
        <p class="text-muted small mb-0"><%= t('set_payments_d') %></p>
      </div></div></div>
      <div class="col-md-6"><div class="card border-0 shadow-sm rounded-4 h-100"><div class="card-body">
        <h6 class="fw-bold mb-1 d-flex align-items-center gap-2"><i data-lucide="megaphone" class="text-primary"></i><%= t('set_announcement_t') %></h6>
        <p class="text-muted small mb-0"><%= t('set_announcement_d') %></p>
      </div></div></div>
    </div>
  </div>
</section>
