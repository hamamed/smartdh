<section class="py-4 py-lg-5">
  <div class="container" style="max-width: 900px;">
    <%- include('_head', { heading: u.name, back: '/admin/users' }) %>

    <% if (ok) { %>
      <div class="alert alert-success py-2 d-flex align-items-center gap-2"><i data-lucide="check"></i>
        <%= ok === 'created' ? t('create_ok') : ok === 'deposit' ? t('manual_dep_ok') : ok === 'withdraw' ? t('manual_wd_ok') : t('profile_saved') %>
      </div>
    <% } %>
    <% if (err) { %>
      <div class="alert alert-danger py-2 d-flex align-items-center gap-2"><i data-lucide="alert-triangle"></i>
        <%= err === 'insufficient' ? t('e_insufficient') : t('manual_err') %>
      </div>
    <% } %>

    <div class="row g-3">
      <!-- Identity -->
      <div class="col-md-5">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body text-center">
            <% if (u.avatar) { %>
              <img src="<%= u.avatar %>" class="rounded-circle mb-3" style="width:88px;height:88px;object-fit:cover" alt="">
            <% } else { %>
              <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center fw-bold mx-auto mb-3"
                   style="width:88px;height:88px;font-size:2rem"><%= u.name.charAt(0).toUpperCase() %></div>
            <% } %>
            <h5 class="fw-bold mb-1"><%= u.name %>
              <% if (u.isAdmin) { %><span class="badge bg-primary-subtle text-primary"><%= t('badge_admin') %></span><% } %>
              <% if (u.isTest) { %><span class="badge bg-warning-subtle text-warning"><%= t('badge_test') %></span><% } %>
            </h5>
            <div class="text-muted small mb-2"><%= u.email %></div>
            <% const sc = u.status==='active'?'success':(u.status==='rejected'?'danger':'warning'); %>
            <span class="badge bg-<%= sc %>-subtle text-<%= sc %> mb-3"><%= statusLabel(u.status) %></span>

            <div class="small text-muted d-flex justify-content-between border-top pt-2" title="<%= new Date(u.createdAt).toLocaleString() %>"><span><%= t('th_joined') %></span><span><%= timeAgo(u.createdAt) %> · <%= new Date(u.createdAt).toLocaleDateString() %></span></div>
            <div class="small text-muted d-flex justify-content-between border-top pt-2"><span><%= t('your_code') %></span><span class="fw-semibold text-uppercase"><%= u.referralCode %></span></div>
            <% if (referrer) { %>
              <div class="small text-muted d-flex justify-content-between border-top pt-2"><span><%= t('invited_by') %></span>
                <a href="/admin/users/<%= referrer.id %>"><%= referrer.name %></a></div>
            <% } %>
            <div class="small text-muted d-flex justify-content-between border-top pt-2"><span><%= t('invited_count') %></span><span class="fw-semibold"><%= invitees.length %></span></div>
            <div class="small text-muted d-flex justify-content-between border-top pt-2"><span><%= t('db_title') %></span><span class="fw-semibold"><%= u.streak.count %></span></div>

            <div class="d-flex gap-1 mt-3">
              <% if (u.status === 'pending') { %>
                <form action="/admin/approve/<%= u.id %>" method="post" class="flex-grow-1"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="btn btn-sm btn-success w-100"><i data-lucide="check" class="me-1"></i><%= t('btn_approve') %></button></form>
              <% } %>
              <form action="/admin/toggle-admin/<%= u.id %>" method="post" class="flex-grow-1"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn btn-sm btn-outline-secondary w-100 d-inline-flex align-items-center justify-content-center gap-1"
                  <%= u.id === currentUser.id ? 'disabled' : '' %>><i data-lucide="user-cog"></i><%= u.isAdmin ? t('make_player') : t('make_admin') %></button></form>
              <form action="/admin/delete/<%= u.id %>" method="post" onsubmit="return confirm('<%= t('confirm_delete') %>')"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn btn-sm btn-outline-danger" <%= u.id === currentUser.id ? 'disabled' : '' %>><i data-lucide="trash-2"></i></button></form>
            </div>
            <% if (!u.isAdmin) { %>
              <form action="/admin/users/<%= u.id %>/toggle-test" method="post" class="mt-2"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn btn-sm w-100 d-inline-flex align-items-center justify-content-center gap-1 <%= u.isTest ? 'btn-outline-success' : 'btn-outline-warning' %>">
                  <i data-lucide="flask-conical"></i><%= u.isTest ? t('test_make_real') : t('test_make_test') %></button></form>
            <% } %>
            <div class="d-flex gap-1 mt-2">
              <form action="/admin/users/<%= u.id %>/impersonate" method="post" class="flex-grow-1"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn btn-sm btn-outline-secondary w-100 d-inline-flex align-items-center justify-content-center gap-1" <%= u.isAdmin ? 'disabled' : '' %>><i data-lucide="eye"></i><%= t('view_as') %></button></form>
              <a href="/admin/users/<%= u.id %>/statement" target="_blank" class="btn btn-sm btn-outline-secondary flex-grow-1 d-inline-flex align-items-center justify-content-center gap-1"><i data-lucide="file-text"></i><%= t('statement') %></a>
            </div>
          </div>
        </div>
      </div>

      <!-- Balances + level -->
      <div class="col-md-7">
        <div class="card border-0 shadow-sm rounded-4 mb-3">
          <div class="card-body">
            <h6 class="fw-bold mb-3 d-flex align-items-center gap-2"><i data-lucide="wallet" class="text-primary"></i><%= t('c_total') %></h6>
            <div class="row g-2 text-center mb-3">
              <div class="col-4"><div class="p-2 rounded-3 wallet wallet-coral">
                <div class="small"><%= t('c_invested') %></div><div class="fw-bold"><%= money(invested) %></div></div></div>
              <div class="col-4"><div class="p-2 rounded-3 wallet wallet-mint">
                <div class="small"><%= t('c_earnings') %></div><div class="fw-bold"><%= money(u.earnings) %></div></div></div>
              <div class="col-4"><div class="p-2 rounded-3 wallet wallet-yellow">
                <div class="small"><%= t('c_total') %></div><div class="fw-bold"><%= money(total) %></div></div></div>
            </div>

            <div class="small text-muted mb-1"><%= t('level_label') %> <%= level %> · <%= t('xp_progress', { have: (u.xp - xpCur), need: (xpNext - xpCur) }) %></div>
            <div class="progress mb-3"><div class="progress-bar" style="width: <%= Math.min(100, Math.round((u.xp - xpCur)/(xpNext - xpCur)*100)) %>%"></div></div>

            <!-- per-app holdings -->
            <div class="small fw-semibold mb-2"><%= t('plans_title') %></div>
            <% plans.forEach(p => { const held = (u.invested && u.invested[p.id]) || 0; %>
              <div class="d-flex justify-content-between border-bottom py-1 small">
                <span class="d-flex align-items-center gap-2"><i data-lucide="<%= p.icon %>" class="text-<%= p.color %>"></i><%= planName(p) %></span>
                <span class="fw-semibold"><%= money(held) %></span>
              </div>
            <% }) %>
          </div>
        </div>

        <!-- Admin actions -->
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-body">
            <h6 class="fw-bold mb-3 d-flex align-items-center gap-2"><i data-lucide="sliders-horizontal" class="text-primary"></i><%= t('th_adjust') %></h6>

            <form action="/admin/adjust/<%= u.id %>" method="post" class="mb-3"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <div class="row g-2">
                <div class="col-6">
                  <label class="form-label small mb-1"><%= t('th_earnings') %></label>
                  <input name="earnings" type="number" step="1" class="form-control form-control-sm" placeholder="<%= Math.round(u.earnings) %>">
                </div>
                <% plans.forEach(p => { %>
                  <div class="col-6">
                    <label class="form-label small mb-1"><%= planName(p) %></label>
                    <input name="plan_<%= p.id %>" type="number" step="1" class="form-control form-control-sm" placeholder="<%= Math.round((u.invested && u.invested[p.id]) || 0) %>">
                  </div>
                <% }) %>
              </div>
              <button class="btn btn-sm btn-primary mt-2 d-inline-flex align-items-center gap-1"><i data-lucide="save"></i><%= t('btn_save') %></button>
              <div class="form-text"><%= t('adjust_hint') %></div>
            </form>

            <hr>
            <form action="/admin/users/<%= u.id %>/xp" method="post" class="mb-3"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <label class="form-label small mb-1"><%= t('set_xp') %></label>
              <div class="input-group input-group-sm" style="max-width:260px">
                <input name="xp" type="number" min="0" class="form-control" value="<%= u.xp %>">
                <span class="input-group-text">XP</span>
                <button class="btn btn-outline-primary"><i data-lucide="save"></i></button>
              </div>
              <div class="form-text"><%= t('set_xp_hint') %></div>
            </form>

            <hr>
            <form action="/admin/users/<%= u.id %>/password" method="post"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <label class="form-label small mb-1"><%= t('set_password') %></label>
              <div class="input-group input-group-sm" style="max-width:320px">
                <input name="password" type="text" minlength="4" class="form-control" placeholder="<%= t('pw_new') %>" required>
                <button class="btn btn-outline-primary"><i data-lucide="key-round"></i></button>
              </div>
              <div class="form-text"><%= t('set_password_hint') %></div>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Manual deposit / withdrawal -->
    <div class="row g-3 mt-0">
      <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body">
            <h6 class="fw-bold mb-3 d-flex align-items-center gap-2"><i data-lucide="receipt" class="text-primary"></i><%= t('manual_dep_t') %></h6>
            <form action="/admin/users/<%= u.id %>/deposit?_csrf=<%= csrfToken %>" method="post" enctype="multipart/form-data"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <div class="row g-2">
                <div class="col-6">
                  <label class="form-label small mb-1"><%= t('th_amount') %></label>
                  <div class="input-group input-group-sm"><input name="amount" type="number" min="1" class="form-control" required><span class="input-group-text"><%= curLabel %></span></div>
                </div>
                <div class="col-6">
                  <label class="form-label small mb-1"><%= t('plans_title') %></label>
                  <select name="plan" class="form-select form-select-sm">
                    <% plans.forEach(p => { %><option value="<%= p.id %>"><%= planName(p) %></option><% }) %>
                  </select>
                </div>
                <div class="col-6">
                  <label class="form-label small mb-1"><%= t('th_status') %></label>
                  <select name="status" class="form-select form-select-sm">
                    <option value="approved"><%= t('st_approved') %></option>
                    <option value="pending"><%= t('st_pending') %></option>
                  </select>
                </div>
                <div class="col-6">
                  <label class="form-label small mb-1"><%= t('manual_date') %></label>
                  <input name="date" type="date" class="form-control form-control-sm">
                </div>
                <div class="col-12">
                  <label class="form-label small mb-1"><%= t('manual_bankref') %></label>
                  <input name="note" class="form-control form-control-sm" placeholder="<%= t('manual_bankref_ph') %>">
                </div>
                <div class="col-12">
                  <label class="form-label small mb-1"><%= t('manual_receipt') %></label>
                  <input name="receipt" type="file" accept="image/*" class="form-control form-control-sm">
                </div>
              </div>
              <button class="btn btn-sm btn-primary mt-2 d-inline-flex align-items-center gap-1"><i data-lucide="plus"></i><%= t('manual_dep_go') %></button>
            </form>
          </div>
        </div>
      </div>

      <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body">
            <h6 class="fw-bold mb-3 d-flex align-items-center gap-2"><i data-lucide="banknote" class="text-primary"></i><%= t('manual_wd_t') %></h6>
            <form action="/admin/users/<%= u.id %>/withdraw" method="post"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <div class="row g-2">
                <div class="col-6">
                  <label class="form-label small mb-1"><%= t('th_amount') %></label>
                  <div class="input-group input-group-sm"><input name="amount" type="number" min="1" class="form-control" required><span class="input-group-text"><%= curLabel %></span></div>
                </div>
                <div class="col-6">
                  <label class="form-label small mb-1"><%= t('th_from') %></label>
                  <select name="from" class="form-select form-select-sm">
                    <option value="earnings"><%= t('opt_earnings') %></option>
                    <% plans.forEach(p => { %><option value="<%= p.id %>"><%= planName(p) %></option><% }) %>
                  </select>
                </div>
                <div class="col-6">
                  <label class="form-label small mb-1"><%= t('payout_method') %></label>
                  <select name="method" class="form-select form-select-sm">
                    <option value="paypal"><%= t('payout_paypal') %></option>
                    <option value="bank"><%= t('payout_bank') %></option>
                  </select>
                </div>
                <div class="col-6">
                  <label class="form-label small mb-1"><%= t('th_status') %></label>
                  <select name="status" class="form-select form-select-sm">
                    <option value="paid"><%= t('st_paid') %></option>
                    <option value="pending"><%= t('st_pending') %></option>
                    <option value="rejected"><%= t('st_rejected') %></option>
                  </select>
                </div>
                <div class="col-6">
                  <label class="form-label small mb-1"><%= t('payout_name') %></label>
                  <input name="payoutName" class="form-control form-control-sm" value="<%= u.payout.name %>">
                </div>
                <div class="col-6">
                  <label class="form-label small mb-1"><%= t('manual_account') %></label>
                  <input name="account" class="form-control form-control-sm" dir="ltr" value="<%= payoutAccount %>">
                </div>
                <div class="col-12">
                  <label class="form-label small mb-1"><%= t('manual_date') %></label>
                  <input name="date" type="date" class="form-control form-control-sm">
                </div>
              </div>
              <button class="btn btn-sm btn-primary mt-2 d-inline-flex align-items-center gap-1"><i data-lucide="minus"></i><%= t('manual_wd_go') %></button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Recurring deposits -->
    <div class="card border-0 shadow-sm rounded-4 mt-3">
      <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
          <h6 class="fw-bold mb-0 d-flex align-items-center gap-2"><i data-lucide="repeat" class="text-primary"></i><%= t('recur_t') %></h6>
          <% if (schedules.length) { %>
            <form action="/admin/schedules/run" method="post" class="mb-0"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="back" value="/admin/users/<%= u.id %>">
              <button class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1"><i data-lucide="play"></i><%= t('recur_run') %></button>
            </form>
          <% } %>
        </div>

        <% if (schedules.length) { %>
          <div class="table-responsive mb-3">
            <table class="table table-sm align-middle mb-0">
              <tbody>
                <% schedules.forEach(sc => { %>
                  <tr>
                    <td class="fw-semibold"><%= money(sc.amount) %></td>
                    <td class="small"><%= sc.planLabel %></td>
                    <td><span class="badge bg-primary-subtle text-primary"><%= t('freq_' + sc.frequency) %></span></td>
                    <td class="small text-muted"><%= t('recur_next') %>: <%= new Date(sc.nextRun).toLocaleDateString() %></td>
                    <td class="text-end">
                      <form action="/admin/schedules/<%= sc.id %>/delete" method="post" class="d-inline"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button class="btn btn-sm btn-outline-danger"><i data-lucide="trash-2"></i></button></form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p class="text-muted small"><%= t('recur_none') %></p>
        <% } %>

        <form action="/admin/users/<%= u.id %>/schedule" method="post" class="row g-2"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="col-md-3">
            <label class="form-label small mb-1"><%= t('th_amount') %></label>
            <div class="input-group input-group-sm"><input name="amount" type="number" min="1" class="form-control" required><span class="input-group-text"><%= curLabel %></span></div>
          </div>
          <div class="col-md-3">
            <label class="form-label small mb-1"><%= t('plans_title') %></label>
            <select name="plan" class="form-select form-select-sm"><% plans.forEach(p => { %><option value="<%= p.id %>"><%= planName(p) %></option><% }) %></select>
          </div>
          <div class="col-md-3">
            <label class="form-label small mb-1"><%= t('recur_freq') %></label>
            <select name="frequency" class="form-select form-select-sm">
              <option value="daily"><%= t('freq_daily') %></option>
              <option value="weekly" selected><%= t('freq_weekly') %></option>
              <option value="monthly"><%= t('freq_monthly') %></option>
            </select>
          </div>
          <div class="col-md-3 d-flex align-items-end">
            <button class="btn btn-sm btn-primary w-100 d-inline-flex align-items-center justify-content-center gap-1"><i data-lucide="plus"></i><%= t('recur_add') %></button>
          </div>
        </form>
        <p class="form-text mb-0"><%= t('recur_hint') %></p>
      </div>
    </div>

    <!-- Payout -->
    <div class="card border-0 shadow-sm rounded-4 mt-3">
      <div class="card-body">
        <h6 class="fw-bold mb-3 d-flex align-items-center gap-2"><i data-lucide="banknote" class="text-primary"></i><%= t('payout_details') %></h6>
        <% if (payoutAccount) { %>
          <div class="row g-2 small">
            <div class="col-md-4"><span class="text-muted"><%= t('payout_method') %></span><div class="fw-semibold"><%= u.payout.method === 'bank' ? t('payout_bank') : t('payout_paypal') %></div></div>
            <div class="col-md-4"><span class="text-muted"><%= t('payout_name') %></span><div class="fw-semibold"><%= u.payout.name || '—' %></div></div>
            <div class="col-md-4"><span class="text-muted"><%= u.payout.method === 'bank' ? t('payout_rib') : t('payout_paypal_email') %></span><div class="fw-semibold" dir="ltr"><%= payoutAccount %></div></div>
          </div>
        <% } else { %>
          <p class="text-muted small mb-0"><%= t('payout_none') %></p>
        <% } %>
      </div>
    </div>

    <!-- Achievements -->
    <div class="card border-0 shadow-sm rounded-4 mt-3">
      <div class="card-body">
        <h6 class="fw-bold mb-3 d-flex align-items-center gap-2"><i data-lucide="trophy" class="text-warning"></i><%= t('ach_title') %>
          <span class="text-muted small">(<%= u.achievements.length %>/<%= Object.keys(ACH).length %>)</span></h6>
        <div class="d-flex flex-wrap gap-2">
          <% Object.keys(ACH).forEach(id => { const got = u.achievements.includes(id); %>
            <span class="badge <%= got ? 'bg-warning-subtle text-warning' : 'bg-body-secondary text-muted opacity-50' %> d-inline-flex align-items-center gap-1 p-2">
              <i data-lucide="<%= ACH[id].icon %>"></i><%= achName(id) %></span>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- History -->
    <div class="row g-3 mt-0">
      <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100"><div class="card-body">
          <h6 class="fw-bold mb-3 d-flex align-items-center gap-2"><i data-lucide="receipt" class="text-primary"></i><%= t('tab_deposits') %></h6>
          <% if (!deposits.length) { %><p class="text-muted small mb-0"><%= t('dv_none') %></p><% } else { %>
            <table class="table table-sm align-middle mb-0"><tbody>
              <% deposits.slice(0,6).forEach(d => { const dc = d.status==='approved'?'success':(d.status==='rejected'?'danger':'warning'); %>
                <tr><td class="fw-semibold"><%= money(d.amount) %></td><td class="small"><%= d.planLabel %></td>
                    <td><span class="badge bg-<%= dc %>-subtle text-<%= dc %>"><%= statusLabel(d.status) %></span></td></tr>
              <% }) %>
            </tbody></table>
          <% } %>
        </div></div>
      </div>
      <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100"><div class="card-body">
          <h6 class="fw-bold mb-3 d-flex align-items-center gap-2"><i data-lucide="banknote" class="text-primary"></i><%= t('tab_withdrawals') %></h6>
          <% if (!withdrawals.length) { %><p class="text-muted small mb-0"><%= t('wd_none') %></p><% } else { %>
            <table class="table table-sm align-middle mb-0"><tbody>
              <% withdrawals.slice(0,6).forEach(w => { const wc = w.status==='paid'?'success':(w.status==='rejected'?'danger':'warning'); %>
                <tr><td class="fw-semibold"><%= money(w.amount) %></td><td class="small"><%= w.fromLabel || w.from %></td>
                    <td><span class="badge bg-<%= wc %>-subtle text-<%= wc %> text-capitalize"><%= w.status %></span></td></tr>
              <% }) %>
            </tbody></table>
          <% } %>
        </div></div>
      </div>
    </div>

    <!-- Activity -->
    <div class="card border-0 shadow-sm rounded-4 mt-3">
      <div class="card-body">
        <h6 class="fw-bold mb-3 d-flex align-items-center gap-2"><i data-lucide="history" class="text-primary"></i><%= t('activity_title') %></h6>
        <% if (!txns.length) { %><p class="text-muted small mb-0"><%= t('no_activity') %></p><% } else { %>
          <div class="list-group list-group-flush">
            <% txns.forEach(tx => { const m = TX[tx.type] || TX.admin_adjust; %>
              <div class="list-group-item px-0 d-flex align-items-center gap-3 bg-transparent">
                <div class="rounded-circle d-flex align-items-center justify-content-center bg-<%= m.cls %>-subtle text-<%= m.cls %>"
                     style="width:34px;height:34px;flex:0 0 34px"><i data-lucide="<%= m.icon %>"></i></div>
                <div class="flex-grow-1">
                  <div class="fw-semibold small"><%= txLabel(tx.type) %></div>
                  <div class="text-muted" style="font-size:.75rem"><%= tx.note %> · <%= new Date(tx.at).toLocaleString() %></div>
                </div>
                <% if (tx.amount) { %><div class="fw-bold text-<%= m.cls %> text-nowrap small"><%= m.sign %><%= money(tx.amount) %></div><% } %>
              </div>
            <% }) %>
          </div>
        <% } %>
