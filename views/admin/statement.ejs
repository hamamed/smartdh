<!doctype html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= t('statement') %> · <%= u.name %></title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=JetBrains+Mono:wght@600;700&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; }
    body { font-family: "Plus Jakarta Sans", "Segoe UI", system-ui, Tahoma, sans-serif; color: #14261c; margin: 0; padding: 32px; background: #f4f6f3; }
    .sheet { max-width: 760px; margin: 0 auto; background: #fff; border: 1px solid #e5eae2; border-radius: 18px; padding: 30px; box-shadow: 0 18px 42px -20px rgba(20,38,28,.22); }
    .head { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid #0e9f6e; padding-bottom: 14px; margin-bottom: 20px; }
    .brand { font-size: 1.4rem; font-weight: 800; color: #0e9f6e; letter-spacing: -.02em; }
    .muted { color: #5f6b62; font-size: .85rem; }
    .who { margin: 18px 0; display: grid; grid-template-columns: 1fr 1fr; gap: 4px 24px; font-size: .9rem; }
    .who div span { color: #5f6b62; }
    table { width: 100%; border-collapse: collapse; font-size: .85rem; margin-top: 8px; }
    th, td { text-align: start; padding: 8px 6px; border-bottom: 1px solid #e5eae2; }
    th { color: #5f6b62; font-weight: 700; text-transform: uppercase; font-size: .72rem; letter-spacing: .04em; }
    .amt { text-align: end; font-weight: 700; font-variant-numeric: tabular-nums; font-family: "JetBrains Mono", ui-monospace, monospace; }
    .in { color: #0b7d57; } .out { color: #d3373c; }
    .tag { font-size: .7rem; padding: 2px 8px; border-radius: 999px; background: #eef1ec; color: #5f6b62; }
    .totals { margin-top: 22px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
    .totals .box { border: 1px solid #e5eae2; border-radius: 12px; padding: 12px; text-align: center; }
    .totals .box .v { font-size: 1.15rem; font-weight: 800; font-family: "JetBrains Mono", ui-monospace, monospace; }
    .foot { margin-top: 26px; font-size: .75rem; color: #8a938b; text-align: center; }
    .noprint { margin-bottom: 18px; }
    @media print { .noprint { display: none; } body { padding: 0; background: #fff; } .sheet { border: 0; box-shadow: none; padding: 0; } }
  </style>
</head>
<body>
  <div class="sheet">
    <div class="noprint">
      <button onclick="window.print()" style="padding:9px 18px;border:0;border-radius:10px;background:#0e9f6e;color:#fff;font-weight:700;cursor:pointer">🖨 <%= t('stmt_print') %></button>
      <a href="/admin/users/<%= u.id %>" style="margin-inline-start:8px;color:#777">← <%= t('nav_back') %></a>
    </div>

    <div class="head">
      <div>
        <% if (settings.brandMode === 'logo' && settings.logoUrl) { %>
          <img src="<%= settings.logoUrl %>" alt="<%= settings.siteName %>" style="height:40px;max-width:220px;object-fit:contain">
        <% } else { %>
          <div class="brand"><%= settings.siteName %></div>
        <% } %>
        <div class="muted"><%= t('stmt_title') %></div>
      </div>
      <div class="muted" style="text-align:end">
        <%= t('stmt_generated') %><br><%= new Date(generatedAt).toLocaleString() %>
      </div>
    </div>

    <div class="who">
      <div><span><%= t('lbl_name') %>:</span> <strong><%= u.name %></strong></div>
      <div><span><%= t('lbl_email') %>:</span> <%= u.email %></div>
      <div><span><%= t('your_code') %>:</span> <%= u.referralCode %></div>
      <div><span><%= t('th_status') %>:</span> <%= statusLabel(u.status) %></div>
    </div>

    <table>
      <thead><tr><th><%= t('th_when') %></th><th><%= t('audit_action') %></th><th><%= t('th_details') %></th><th class="amt"><%= t('th_amount') %></th><th><%= t('th_status') %></th></tr></thead>
      <tbody>
        <% if (!rows.length) { %>
          <tr><td colspan="5" class="muted"><%= t('no_activity') %></td></tr>
        <% } %>
        <% rows.forEach(r => { const inflow = r.kind === 'deposit'; %>
          <tr>
            <td><%= new Date(r.t).toLocaleDateString() %></td>
            <td><%= inflow ? t('tx_deposit') : t('tab_withdrawals') %></td>
            <td><%= r.label %><% if (r.note) { %> <span class="tag"><%= r.note %></span><% } %></td>
            <td class="amt <%= inflow ? 'in' : 'out' %>"><%= inflow ? '+' : '−' %><%= money(r.amount) %></td>
            <td><span class="tag"><%= statusLabel(r.status) || r.status %></span></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <div class="totals">
      <div class="box"><span class="muted"><%= t('c_invested') %></span><div class="v"><%= money(invested) %></div></div>
      <div class="box"><span class="muted"><%= t('c_earnings') %></span><div class="v"><%= money(u.earnings) %></div></div>
      <div class="box"><span class="muted"><%= t('c_total') %></span><div class="v"><%= money(total) %></div></div>
    </div>

    <div class="foot"><%= t('footer_strong') %> <%= t('footer_rest') %></div>
  </div>
</body>
</html>
