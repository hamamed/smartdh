<section class="py-4 py-lg-5">
  <div class="container">
    <div class="d-flex align-items-center justify-content-between gap-2 mb-4 flex-wrap">
      <div class="d-flex align-items-center gap-2">
        <a href="/admin" class="btn btn-outline-secondary btn-icon rounded-circle"><i data-lucide="arrow-left"></i></a>
        <h3 class="fw-bold mb-0"><%= t('tab_users') %></h3>
      </div>
      <button class="btn btn-primary btn-sm d-inline-flex align-items-center gap-1" type="button"
              data-bs-toggle="collapse" data-bs-target="#createBox"><i data-lucide="user-plus"></i><%= t('create_user') %></button>
    </div>

    <% if (created) { %>
      <div class="alert alert-<%= created === 'ok' ? 'success' : 'danger' %> py-2 d-flex align-items-center gap-2">
        <i data-lucide="<%= created === 'ok' ? 'check' : 'alert-triangle' %>"></i>
        <%= created === 'dup' ? t('create_dup') : created === 'err' ? t('create_err') : t('create_ok') %>
      </div>
    <% } %>

    <div class="collapse mb-4" id="createBox">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body">
          <h6 class="fw-bold mb-3 d-flex align-items-center gap-2"><i data-lucide="user-plus" class="text-primary"></i><%= t('create_user_t') %></h6>
          <form method="post" action="/admin/users/create" class="row g-2">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="col-md-4"><label class="form-label small"><%= t('lbl_name') %></label><input name="name" class="form-control" required></div>
            <div class="col-md-4"><label class="form-label small"><%= t('lbl_email') %></label><input name="email" type="email" class="form-control" required></div>
            <div class="col-md-2"><label class="form-label small"><%= t('lbl_password') %></label><input name="password" type="text" minlength="4" class="form-control" required></div>
            <div class="col-md-2"><label class="form-label small"><%= t('th_status') %></label>
              <select name="status" class="form-select">
                <option value="active"><%= t('st_active') %></option>
                <option value="pending"><%= t('st_pending') %></option>
              </select></div>
            <div class="col-12 d-flex flex-wrap align-items-center gap-3">
              <button class="btn btn-primary d-inline-flex align-items-center gap-1"><i data-lucide="user-plus"></i><%= t('create_user') %></button>
              <div class="form-check mb-0">
                <input class="form-check-input" type="checkbox" name="isTest" id="isTest" value="1">
                <label class="form-check-label small" for="isTest"><%= t('create_as_test') %></label>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body">
        <div class="d-flex flex-wrap gap-2 mb-3 align-items-center">
          <form method="get" action="/admin/users" class="d-flex gap-2" style="max-width:420px">
            <% if (per !== 10) { %><input type="hidden" name="per" value="<%= per %>"><% } %>
            <div class="input-group input-group-sm">
              <span class="input-group-text"><i data-lucide="search"></i></span>
              <input name="q" class="form-control" placeholder="<%= t('search_users') %>" value="<%= q %>">
            </div>
            <button class="btn btn-sm btn-primary"><%= t('btn_search') %></button>
          </form>
          <div class="ms-auto d-flex gap-2 flex-wrap align-items-center">
            <%- include('_filters', {
                  keep: (per !== 10 ? '&per=' + per : ''), base: '/admin/users', current: status, q: q,
                  options: [
                    { value: '',         label: t('filter_all'),   count: totalUsersAll },
                    { value: 'pending',  label: t('st_pending'),   count: statusCounts.pending  || 0, danger: true },
                    { value: 'active',   label: t('st_active'),    count: statusCounts.active   || 0 },
                    { value: 'rejected', label: t('st_rejected'),  count: statusCounts.rejected || 0 }
                  ]
                }) %>
            <a href="/admin/export/users.csv" class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1"><i data-lucide="download"></i><%= t('export_users') %></a>
          </div>
        </div>

        <% if (done) { %>
          <div class="alert alert-<%= done === 'none' ? 'warning' : 'success' %> py-2 d-flex align-items-center gap-2">
            <i data-lucide="<%= done === 'none' ? 'alert-triangle' : 'check' %>"></i>
            <%= done === 'none' ? t('bulk_none') : t('bulk_done_' + done, { n: doneN }) %>
          </div>
        <% } %>

        <% if (users.length === 0) { %>
          <p class="text-muted mb-0"><%= t('no_results') %></p>
        <% } else { %>
          <%# lives outside the table: the rows already contain their own forms,
              and nesting forms is invalid — checkboxes link to it via form="bulkForm" %>
          <form id="bulkForm" method="post" action="/admin/users/bulk"
                onsubmit="return dvConfirmBulk(this)">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          </form>

          <div id="bulkBar" class="d-none align-items-center gap-2 p-2 mb-2 rounded-3 bg-body-secondary">
            <span class="small fw-semibold ms-2"><span id="bulkCount">0</span> <%= t('bulk_selected') %></span>
            <div class="ms-auto d-flex gap-1 flex-wrap">
              <button type="button" id="batchDepBtn" class="btn btn-sm btn-primary d-inline-flex align-items-center gap-1"
                      data-bs-toggle="modal" data-bs-target="#batchDepModal"><i data-lucide="receipt"></i><%= t('batch_dep') %></button>
              <button form="bulkForm" name="action" value="approve" class="btn btn-sm btn-success d-inline-flex align-items-center gap-1">
                <i data-lucide="check"></i><%= t('btn_approve') %></button>
              <button form="bulkForm" name="action" value="reject" class="btn btn-sm btn-outline-danger d-inline-flex align-items-center gap-1">
                <i data-lucide="x"></i><%= t('bulk_reject') %></button>
              <button form="bulkForm" name="action" value="delete" class="btn btn-sm btn-danger d-inline-flex align-items-center gap-1">
                <i data-lucide="trash-2"></i><%= t('bulk_delete') %></button>
            </div>
          </div>

          <div class="table-responsive">
            <table class="table align-middle mb-0" id="usersTable">
              <thead class="text-muted small">
                <tr>
                  <th style="width:34px">
                    <input type="checkbox" class="form-check-input" id="checkAll" title="<%= t('bulk_selectall') %>">
                  </th>
                  <th><%= t('th_user') %></th><th><%= t('th_status') %></th><th><%= t('level_label') %></th>
                  <th><%= t('th_invested') %></th><th><%= t('th_earnings') %></th><th class="text-end"><%= t('th_action') %></th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach(u => { const sc = u.status==='active'?'success':(u.status==='rejected'?'danger':'warning'); %>
                  <tr>
                    <td>
                      <input type="checkbox" class="form-check-input row-check" form="bulkForm"
                             name="ids" value="<%= u.id %>"
                             <%= u.id === currentUser.id ? 'disabled title="' + t('bulk_notyou') + '"' : '' %>>
                    </td>
                    <td>
                      <div class="d-flex align-items-center gap-2">
                        <% if (u.avatar) { %>
                          <img src="<%= u.avatar %>" class="rounded-circle" style="width:36px;height:36px;object-fit:cover" alt="">
                        <% } else { %>
                          <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center fw-bold"
                               style="width:36px;height:36px;flex:0 0 36px"><%= u.name.charAt(0).toUpperCase() %></div>
                        <% } %>
                        <div>
                          <div class="fw-semibold"><%= u.name %>
                            <% if (u.isAdmin) { %><span class="badge bg-primary-subtle text-primary ms-1"><%= t('badge_admin') %></span><% } %>
                          </div>
                          <div class="small text-muted"><%= u.email %></div>
                          <% if (u.createdAt) { %>
                            <div class="text-muted d-flex align-items-center gap-1" style="font-size:.72rem" title="<%= t('th_joined') %>: <%= new Date(u.createdAt).toLocaleString() %>">
                              <i data-lucide="clock" style="width:.85em;height:.85em"></i><%= timeAgo(u.createdAt) %>
                            </div>
                          <% } %>
                        </div>
                      </div>
                    </td>
                    <td><span class="badge bg-<%= sc %>-subtle text-<%= sc %>"><%= statusLabel(u.status) %></span></td>
                    <td><span class="badge bg-body-secondary text-muted"><%= levelForXp(u.xp) %></span></td>
                    <td class="fw-semibold"><%= money(totalInvested(u)) %></td>
                    <td class="fw-semibold text-success"><%= money(u.earnings) %></td>
                    <td class="text-end text-nowrap">
                      <% if (u.status === 'pending') { %>
                        <form action="/admin/approve/<%= u.id %>" method="post" class="d-inline"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button class="btn btn-sm btn-success"><i data-lucide="check" class="me-1"></i><%= t('btn_approve') %></button>
                        </form>
                        <form action="/admin/reject/<%= u.id %>" method="post" class="d-inline"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button class="btn btn-sm btn-outline-danger"><i data-lucide="x"></i></button>
                        </form>
                      <% } %>
                      <a href="/admin/users/<%= u.id %>" class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1">
                        <i data-lucide="eye"></i><%= t('btn_manage') %></a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <% const kept = (status ? '&status=' + status : '') + (q ? '&q=' + encodeURIComponent(q) : ''); %>
          <div class="d-flex flex-wrap justify-content-between align-items-center mt-3 gap-2">
            <span class="small text-muted"><%= t('showing_n', { shown: users.length, total: totalUsers }) %></span>
            <%- include('_perpage', { base: '/admin/users', per: per, options: perOptions, qs: kept }) %>
            <%- include('_pager', { base: '/admin/users', page: page, pages: pages, qs: kept + '&per=' + per }) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>

<!-- Batch deposit modal -->
<div class="modal fade" id="batchDepModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 rounded-4">
      <form method="post" action="/admin/users/batch-deposit" id="batchDepForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="modal-body p-4">
          <h5 class="fw-bold mb-1 d-flex align-items-center gap-2"><i data-lucide="receipt" class="text-primary"></i><%= t('batch_dep_t') %></h5>
          <p class="text-muted small mb-3"><span id="batchCount">0</span> <%= t('bulk_selected') %></p>
          <div id="batchIds"></div>
          <div class="row g-2">
            <div class="col-6">
              <label class="form-label small"><%= t('th_amount') %></label>
              <div class="input-group input-group-sm"><input name="amount" type="number" min="1" class="form-control" required><span class="input-group-text"><%= curLabel %></span></div>
            </div>
            <div class="col-6">
              <label class="form-label small"><%= t('plans_title') %></label>
              <select name="plan" class="form-select form-select-sm"><% plans.forEach(p => { %><option value="<%= p.id %>"><%= planName(p) %></option><% }) %></select>
            </div>
            <div class="col-12">
              <label class="form-label small"><%= t('th_status') %></label>
              <select name="status" class="form-select form-select-sm">
                <option value="approved"><%= t('st_approved') %></option>
                <option value="pending"><%= t('st_pending') %></option>
              </select>
            </div>
          </div>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal"><%= t('tour_skip') %></button>
          <button class="btn btn-primary btn-sm d-inline-flex align-items-center gap-1"><i data-lucide="plus"></i><%= t('batch_dep_go') %></button>
        </div>
      </form>
    </div>
  </div>
</div>
