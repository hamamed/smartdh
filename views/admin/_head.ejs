<%# Shared admin page header: back arrow + title. Pass `heading`, optional `back`. %>
<div class="d-flex align-items-center gap-2 mb-4">
  <a href="<%= typeof back !== 'undefined' ? back : '/admin' %>" class="btn btn-outline-secondary btn-icon rounded-circle"><i data-lucide="arrow-left"></i></a>
  <h3 class="fw-bold mb-0"><%= heading %></h3>
</div>
