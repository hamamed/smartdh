<section class="py-4 py-lg-5">
  <div class="container">
    <%- include('_head', { heading: t('tab_deposits') }) %>

    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body">
        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
          <form method="get" action="/admin/deposits" class="d-flex gap-2" style="max-width:320px">
            <% if (status) { %><input type="hidden" name="status" value="<%= status %>"><% } %>
            <div class="input-group input-group-sm">
              <span class="input-group-text"><i data-lucide="search"></i></span>
              <input name="q" class="form-control" placeholder="<%= t('search_player') %>" value="<%= q %>">
            </div>
            <button class="btn btn-sm btn-primary"><%= t('btn_search') %></button>
          </form>
          <div class="ms-auto d-flex gap-2 flex-wrap align-items-center">
            <%- include('_filters', {
                  base: '/admin/deposits', current: status, q: q,
                  options: [
                    { value: '',         label: t('filter_all'),  count: (statusCounts.pending||0)+(statusCounts.approved||0)+(statusCounts.rejected||0) },
                    { value: 'pending',  label: t('st_pending'),  count: statusCounts.pending  || 0, danger: true },
                    { value: 'approved', label: t('st_approved'), count: statusCounts.approved || 0 },
                    { value: 'rejected', label: t('st_rejected'), count: statusCounts.rejected || 0 }
                  ]
                }) %>
            <a href="/admin/export/deposits.csv" class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1"><i data-lucide="download"></i><%= t('export_deposits') %></a>
          </div>
        </div>
        <% if (deposits.length === 0) { %>
          <p class="text-muted mb-0"><%= t('no_results') %></p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table align-middle mb-0">
              <thead class="text-muted small"><tr><th><%= t('th_user') %></th><th><%= t('th_amount') %></th><th><%= t('th_plan') %></th><th><%= t('th_status') %></th><th><%= t('th_when') %></th><th class="text-end"><%= t('th_action') %></th></tr></thead>
              <tbody>
                <% deposits.forEach(d => { const dc = d.status==='approved'?'success':(d.status==='rejected'?'danger':'warning'); %>
                  <tr>
                    <td><a href="/admin/users/<%= d.userId %>" class="fw-semibold"><%= d.userName %></a></td>
                    <td class="fw-semibold"><%= money(d.amount) %></td>
                    <td class="small"><%= d.planLabel %></td>
                    <td><span class="badge bg-<%= dc %>-subtle text-<%= dc %>"><%= statusLabel(d.status) %></span></td>
                    <td class="small text-muted"><%= new Date(d.createdAt).toLocaleString() %></td>
                    <td class="text-end text-nowrap">
                      <% if (d.status === 'pending') { %>
                        <form action="/admin/deposit/<%= d.id %>/approve" method="post" class="d-inline"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button class="btn btn-sm btn-success"><i data-lucide="check" class="me-1"></i><%= t('btn_approve') %></button></form>
                        <form action="/admin/deposit/<%= d.id %>/reject" method="post" class="d-inline"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button class="btn btn-sm btn-outline-danger"><i data-lucide="x"></i></button></form>
                      <% } else { %><span class="text-muted small">—</span><% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <div class="d-flex flex-wrap justify-content-between align-items-center mt-3 gap-2">
            <span class="small text-muted"><%= t('showing_n', { shown: deposits.length, total: total }) %></span>
            <%- include('_pager', {
                  base: '/admin/deposits', page: page, pages: pages,
                  qs: (status ? '&status=' + status : '') + (q ? '&q=' + encodeURIComponent(q) : '')
                }) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>
