<section class="py-4 py-lg-5">
  <div class="container">
    <%- include('_head', { heading: t('tab_deposits') }) %>

    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body">
        <div class="d-flex justify-content-end mb-3">
          <a href="/admin/export/deposits.csv" class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1"><i data-lucide="download"></i><%= t('export_deposits') %></a>
        </div>
        <% if (deposits.length === 0) { %>
          <p class="text-muted mb-0"><%= t('dv_none') %></p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table align-middle mb-0">
              <thead class="text-muted small"><tr><th><%= t('th_user') %></th><th><%= t('th_amount') %></th><th><%= t('th_plan') %></th><th><%= t('th_status') %></th><th><%= t('th_when') %></th><th class="text-end"><%= t('th_action') %></th></tr></thead>
              <tbody>
                <% deposits.forEach(d => { const dc = d.status==='approved'?'success':(d.status==='rejected'?'danger':'warning'); %>
                  <tr>
                    <td><a href="/admin/users/<%= d.userId %>" class="fw-semibold"><%= d.userName %></a></td>
                    <td class="fw-semibold"><%= money(d.amount) %></td>
                    <td class="small"><%= d.planLabel %></td>
                    <td><span class="badge bg-<%= dc %>-subtle text-<%= dc %>"><%= statusLabel(d.status) %></span></td>
                    <td class="small text-muted"><%= new Date(d.createdAt).toLocaleString() %></td>
                    <td class="text-end text-nowrap">
                      <% if (d.status === 'pending') { %>
                        <form action="/admin/deposit/<%= d.id %>/approve" method="post" class="d-inline"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button class="btn btn-sm btn-success"><i data-lucide="check" class="me-1"></i><%= t('btn_approve') %></button></form>
                        <form action="/admin/deposit/<%= d.id %>/reject" method="post" class="d-inline"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button class="btn btn-sm btn-outline-danger"><i data-lucide="x"></i></button></form>
                      <% } else { %><span class="text-muted small">—</span><% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>
