<section class="py-4 py-lg-5">
  <div class="container" style="max-width: 640px;">
    <div class="d-flex align-items-center gap-2 mb-4">
      <a href="/dashboard" class="btn btn-outline-secondary btn-icon rounded-circle"><i data-lucide="arrow-left"></i></a>
      <h3 class="fw-bold mb-0"><%= t('withdraw_title') %></h3>
    </div>

    <div id="flash"></div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
      <div class="card-body">
        <% if (!depositOk) { %>
          <div class="alert alert-warning small d-flex align-items-center gap-2 mb-3">
            <i data-lucide="alert-triangle"></i><span><%= t('e_needdeposit') %></span>
          </div>
          <a href="/invest" class="btn btn-primary w-100 d-inline-flex align-items-center justify-content-center gap-1"><i data-lucide="plus"></i><%= t('bonus_go_deposit') %></a>
        <% } else { %>
        <form method="post" action="/withdraw"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <select name="from" class="form-select mb-2">
            <option value="earnings"><%= t('opt_earnings') %> (<%= money(currentUser.earnings) %>)</option>
            <% plans.forEach(p => { const f = funds[p.id] || { held:0, locked:0, available:0 }; %>
              <option value="<%= p.id %>"><%= planName(p) %> (<%= money(f.available) %><% if (f.locked > 0) { %> · <%= t('wd_locked_opt', { amt: money(f.locked) }) %><% } %>)</option>
            <% }) %>
          </select>

          <% const lockedApps = plans.filter(p => (funds[p.id]||{}).locked > 0); %>
          <% if (lockDays > 0 && lockedApps.length) { %>
            <div class="alert alert-warning py-2 small mb-2">
              <div class="d-flex align-items-center gap-1 fw-semibold mb-1"><i data-lucide="lock"></i><%= t('wd_lock_title', { days: lockDays }) %></div>
              <% lockedApps.forEach(p => { const f = funds[p.id]; %>
                <div class="pt-1">
                  <div class="d-flex justify-content-between gap-2">
                    <span class="fw-semibold text-truncate"><%= planName(p) %></span>
                    <span class="fw-semibold text-nowrap flex-shrink-0"><%= money(f.locked) %></span>
                  </div>
                  <% if (f.unlockAt) { %><div class="text-muted" style="font-size:.78rem"><%= t('wd_unlocks', { date: new Date(f.unlockAt).toLocaleDateString() }) %></div><% } %>
                </div>
              <% }) %>
            </div>
          <% } %>
          <div class="input-group mb-2">
            <span class="input-group-text"><i data-lucide="banknote"></i></span>
            <input name="amount" type="number" min="<%= settings.minWithdraw %>" step="1" class="form-control" placeholder="<%= t('amount_ph') %>" required>
            <span class="input-group-text"><%= curLabel %></span>
          </div>
          <hr class="my-3">

          <% if (payoutOk) { %>
            <!-- payout details come from the profile — no need to type them again -->
            <div class="d-flex align-items-center gap-3 p-3 rounded-3 bg-body-secondary mb-3">
              <span class="tile-icon ti-mint" style="width:42px;height:42px;font-size:1.1rem">
                <i data-lucide="<%= currentUser.payout.method === 'bank' ? 'landmark' : 'wallet' %>"></i>
              </span>
              <div class="flex-grow-1 small">
                <div class="text-muted"><%= t('payout_sending_to') %></div>
                <div class="fw-semibold"><%= currentUser.payout.name %>
                  <span class="badge bg-primary-subtle text-primary ms-1"><%= currentUser.payout.method === 'bank' ? t('payout_bank') : t('payout_paypal') %></span>
                </div>
                <div class="text-muted" dir="ltr" style="overflow-wrap:anywhere;word-break:break-all"><%= payoutAccount %></div>
              </div>
              <a href="/profile" class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1">
                <i data-lucide="pencil"></i><%= t('payout_change') %>
              </a>
            </div>
            <button class="btn btn-success w-100 d-inline-flex align-items-center justify-content-center gap-1"><i data-lucide="arrow-down"></i><%= t('btn_request') %></button>
          <% } else { %>
            <div class="alert alert-warning small d-flex align-items-center gap-2 mb-3">
              <i data-lucide="alert-triangle"></i><span><%= t('payout_missing_d') %></span>
            </div>
            <a href="/profile" class="btn btn-primary w-100 d-inline-flex align-items-center justify-content-center gap-1">
              <i data-lucide="settings"></i><%= t('payout_setup') %>
            </a>
          <% } %>
          <p class="small text-muted mt-2 mb-0"><%= t('withdraw_note', { min: money(settings.minWithdraw), days: settings.withdrawEveryDays }) %></p>
        </form>
        <% } %>
      </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body">
        <h6 class="fw-bold mb-3 d-flex align-items-center gap-2"><i data-lucide="history" class="text-primary"></i><%= t('activity_title') %></h6>
        <% if (myWithdrawals.length === 0) { %>
          <p class="text-muted small mb-0"><%= t('no_activity') %></p>
        <% } else { %>
          <div class="list-group list-group-flush">
            <% myWithdrawals.forEach(w => { const wc = w.status==='paid'?'success':(w.status==='rejected'?'danger':'warning'); %>
              <div class="list-group-item px-0 d-flex align-items-center gap-2 bg-transparent">
                <div class="flex-grow-1 min-w-0">
                  <div class="fw-semibold small text-truncate"><%= w.fromLabel || w.from %></div>
                  <div class="text-muted" style="font-size:.75rem"><span data-ago="<%= w.createdAt %>" title="<%= new Date(w.createdAt).toLocaleString() %>"><%= timeAgo(w.createdAt) %></span></div>
                </div>
                <span class="badge bg-<%= wc %>-subtle text-<%= wc %> text-capitalize flex-shrink-0"><%= w.status %></span>
                <div class="fw-bold text-nowrap flex-shrink-0 small"><%= money(w.amount) %></div>
                <a href="/invoice/withdraw/<%= w.id %>" target="_blank" rel="noopener" class="btn btn-sm btn-outline-secondary btn-icon flex-shrink-0" style="width:30px;height:30px" title="<%= t('inv_title') %>"><i data-lucide="file-text"></i></a>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>
