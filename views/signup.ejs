<section class="py-5">
  <div class="container" style="max-width: 460px;">
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-4 p-md-5">
        <h3 class="fw-bold mb-1"><%= t('signup_title') %></h3>
        <p class="text-muted mb-4"><%= t('signup_sub') %></p>

        <% if (error) { %>
          <div class="alert alert-danger py-2"><i data-lucide="alert-triangle" class="me-1"></i><%= error %></div>
        <% } %>

        <form method="post" action="/signup"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="mb-3">
            <label class="form-label"><%= t('lbl_name') %></label>
            <input name="name" class="form-control" value="<%= form.name || '' %>" required>
          </div>
          <div class="mb-3">
            <label class="form-label"><%= t('lbl_email') %></label>
            <input name="email" type="email" class="form-control" value="<%= form.email || '' %>" required>
          </div>
          <div class="mb-3">
            <label class="form-label"><%= t('lbl_password') %></label>
            <input name="password" type="password" class="form-control" minlength="4" required>
          </div>
          <div class="mb-3">
            <label class="form-label"><%= t('lbl_ref') %> <span class="text-muted small"><%= t('opt') %></span></label>
            <input name="ref" class="form-control text-uppercase" value="<%= form.ref || '' %>" placeholder="<%= t('ref_ph') %>">
          </div>
          <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" name="agree" id="agree" value="1" required>
            <label class="form-check-label small" for="agree"><%- t('agree_html') %></label>
          </div>
          <button class="btn btn-primary w-100 py-2"><i data-lucide="user-plus" class="me-1"></i><%= t('btn_create') %></button>
        </form>

        <p class="text-center text-muted small mt-4 mb-0">
          <%= t('have_account') %> <a href="/login"><%= t('link_login') %></a>
        </p>
      </div>
    </div>
  </div>
</section>
