<!-- ============================================================ HERO -->
<section class="lp-hero py-5">
  <div class="container py-lg-5">
    <div class="row align-items-center g-5">
      <div class="col-lg-6">
        <span class="lp-eyebrow mb-3"><i data-lucide="trophy"></i><%= t('hero_badge') %></span>
        <h1 class="lp-title fw-bold mb-3"><%= t('hero_title') %></h1>
        <p class="lp-lead text-muted mb-4"><%= t('hero_desc') %></p>

        <div class="d-flex gap-2 flex-wrap mb-4">
          <a href="/signup" class="btn btn-primary btn-lg px-4 d-inline-flex align-items-center gap-2">
            <i data-lucide="rocket"></i><%= t('btn_getstarted') %>
          </a>
          <a href="/login" class="btn btn-outline-secondary btn-lg px-4"><%= t('btn_login') %></a>
        </div>

        <div class="lp-trust">
          <% [['layers','lp_chip_1'], ['trophy','lp_chip_2'], ['arrow-down-to-line','lp_chip_3']].forEach(([icon, key]) => { %>
            <span class="chip"><i data-lucide="<%= icon %>"></i><%= t(key) %></span>
          <% }) %>
        </div>
      </div>

      <!-- Earnings calculator -->
      <div class="col-lg-6">
        <div class="card calc-card border-0 rounded-4">
          <div class="card-body">
            <h5 class="fw-bold mb-3 d-flex align-items-center gap-2"><i data-lucide="calculator" class="text-primary"></i><%= t('calc_title') %></h5>

            <label class="form-label small text-muted mb-1"><%= t('calc_choose_plan') %></label>
            <select id="calcPlan" class="form-select mb-3">
              <% plans.forEach(p => { %>
                <option value="<%= p.ratePer15Days %>" <%= p.id==='balanced'?'selected':'' %>>
                  <%= planName(p) %> — <%= (p.ratePer15Days*100).toFixed(1) %>% <%= t('per15_suffix') %>
                </option>
              <% }) %>
            </select>

            <label class="form-label small text-muted mb-1"><%= t('calc_ifinvest') %></label>
            <div class="input-group input-group-lg mb-4">
              <span class="input-group-text"><i data-lucide="wallet"></i></span>
              <input type="number" id="calcAmount" class="form-control" value="10000" min="0" step="100">
              <span class="input-group-text"><%= curLabel %></span>
            </div>

            <div class="row g-2 text-center" data-currency="<%= curLabel %>">
              <div class="col-4"><div class="calc-out wallet wallet-coral">
                <div class="small mb-1"><%= t('lbl_daily') %></div>
                <div class="fw-bold" id="calcDaily">—</div></div></div>
              <div class="col-4"><div class="calc-out wallet wallet-mint">
                <div class="small mb-1"><%= t('lbl_15days') %></div>
                <div class="fw-bold" id="calc15">—</div></div></div>
              <div class="col-4"><div class="calc-out wallet wallet-yellow">
                <div class="small mb-1"><%= t('lbl_monthly') %></div>
                <div class="fw-bold" id="calcMonthly">—</div></div></div>
            </div>
            <p class="small text-muted mt-3 mb-0 d-flex align-items-center gap-1"><i data-lucide="info"></i><%= t('calc_note') %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============================================ LIVE STATS (real data only) -->
<% if (stats) { %>
  <section class="pb-2">
    <div class="container">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body py-4">
          <div class="row g-3 text-center">
            <% [
                 ['users', 'ti-coral',  stats.players.toLocaleString(), 'stat_players'],
                 ['coins', 'ti-mint',   money(stats.coins),             'stat_total'],
                 ['layers','ti-sky',    stats.apps,                     'plans_title'],
                 ['banknote','ti-yellow', stats.payouts.toLocaleString(), 'lp_stat_payouts']
               ].forEach(([icon, tint, value, key]) => { %>
              <div class="col-6 col-lg-3">
                <span class="tile-icon <%= tint %> mx-auto mb-2" style="width:46px;height:46px;font-size:1.2rem"><i data-lucide="<%= icon %>"></i></span>
                <div class="h4 fw-bold mb-0"><%= value %></div>
                <div class="small text-muted"><%= t(key) %></div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </section>
<% } %>

<!-- ================================================================ WHAT IS IT -->
<section class="py-5 mt-2">
  <div class="container">
    <div class="text-center mx-auto mb-5" style="max-width: 720px;">
      <span class="sec-eyebrow"><%= t('hero_badge') %></span>
      <h2 class="sec-title fw-bold mb-3"><%= t('lp_what_t', { site: settings.siteName }) %></h2>
      <p class="text-muted mb-0 lh-lg"><%= t('lp_what_d') %></p>
    </div>
    <div class="row g-3">
      <%
        const pillars = [
          { icon: 'shield-check', tint: 'mint',   t: 'lp_pillar_1_t', d: 'lp_pillar_1_d' },
          { icon: 'layers',       tint: 'coral',  t: 'lp_pillar_2_t', d: 'lp_pillar_2_d' },
          { icon: 'medal',        tint: 'yellow', t: 'lp_pillar_3_t', d: 'lp_pillar_3_d' }
        ];
      %>
      <% pillars.forEach(p => { %>
        <div class="col-md-4">
          <div class="lp-card text-center p-4">
            <span class="tile-icon ti-<%= p.tint %> mx-auto mb-3" style="width:60px;height:60px;font-size:1.5rem"><i data-lucide="<%= p.icon %>"></i></span>
            <h6 class="fw-bold mb-2"><%= t(p.t) %></h6>
            <p class="text-muted small mb-0 lh-lg"><%= t(p.d) %></p>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- =============================================================== HOW IT WORKS -->
<section class="py-5 bg-body border-top">
  <div class="container">
    <div class="text-center mb-5">
      <span class="sec-eyebrow"><%= t('lp_steps_d') %></span>
      <h2 class="sec-title fw-bold mb-0"><%= t('lp_steps_t') %></h2>
    </div>
    <div class="row g-4 lp-steps">
      <%
        const steps = [
          { icon: 'user-plus',   text: t('howto_invest_1') },
          { icon: 'layers',      text: t('howto_invest_2', { min: money(settings.minAddFunds) }) },
          { icon: 'shield',      text: t('howto_invest_3') },
          { icon: 'trending-up', text: t('howto_invest_4') }
        ];
      %>
      <% steps.forEach((s, i) => { %>
        <div class="col-md-6 col-lg-3">
          <div class="lp-step h-100">
            <div class="d-flex align-items-center gap-2 mb-3">
              <span class="step-num"><%= i + 1 %></span>
              <span class="tile-icon ti-navy" style="width:44px;height:44px;font-size:1.15rem"><i data-lucide="<%= s.icon %>"></i></span>
            </div>
            <p class="text-muted small mb-0 lh-lg"><%= s.text %></p>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ================================================================ WAYS TO EARN -->
<section class="py-5">
  <div class="container">
    <div class="text-center mb-5">
      <span class="sec-eyebrow"><%= t('lp_earn_d') %></span>
      <h2 class="sec-title fw-bold mb-0"><%= t('howto_earn_t') %></h2>
    </div>
    <div class="row g-3">
      <%
        const earn = [
          { icon: 'coins',     tint: 'mint',   t: 'howto_earn_1_t', d: t('howto_earn_1_d') },
          { icon: 'gift',      tint: 'yellow', t: 'howto_earn_2_t', d: t('howto_earn_2_d', { max: money(settings.dailyBonusBase * 7) }) },
          { icon: 'user-plus', tint: 'coral',  t: 'howto_earn_3_t', d: t('howto_earn_3_d', { t1: settings.referralTiers[0]*100, t2: settings.referralTiers[1]*100, t3: settings.referralTiers[2]*100 }) },
          { icon: 'trophy',    tint: 'lilac',  t: 'howto_earn_4_t', d: t('howto_earn_4_d') }
        ];
      %>
      <% earn.forEach(e => { %>
        <div class="col-md-6 col-lg-3">
          <div class="lp-card text-center p-4">
            <span class="tile-icon ti-<%= e.tint %> mx-auto mb-3" style="width:58px;height:58px;font-size:1.5rem"><i data-lucide="<%= e.icon %>"></i></span>
            <h6 class="fw-bold mb-2"><%= t(e.t) %></h6>
            <p class="text-muted small mb-0 lh-lg"><%= e.d %></p>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ========================================================= LEVELS & WITHDRAWALS -->
<section class="py-5 bg-body border-top">
  <div class="container">
    <div class="text-center mb-5">
      <span class="sec-eyebrow"><%= t('guide_title') %></span>
      <h2 class="sec-title fw-bold mb-2"><%= t('lp_more_t') %></h2>
      <a href="/guide" class="d-inline-flex align-items-center gap-1"><i data-lucide="book-open"></i><%= t('guide_title') %></a>
    </div>
    <div class="row g-3 justify-content-center">
      <div class="col-md-6">
        <div class="lp-card p-4 d-flex align-items-start gap-3">
          <span class="tile-icon ti-yellow" style="width:48px;height:48px;font-size:1.25rem"><i data-lucide="star"></i></span>
          <div>
            <h6 class="fw-bold mb-2"><%= t('howto_level_t') %></h6>
            <p class="text-muted small mb-0 lh-lg"><%= t('howto_level_d') %></p>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="lp-card p-4 d-flex align-items-start gap-3">
          <span class="tile-icon ti-sky" style="width:48px;height:48px;font-size:1.25rem"><i data-lucide="arrow-down-to-line"></i></span>
          <div>
            <h6 class="fw-bold mb-2"><%= t('howto_withdraw_t') %></h6>
            <p class="text-muted small mb-0 lh-lg"><%= t('howto_withdraw_d', { min: money(settings.minWithdraw), days: settings.withdrawEveryDays }) %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ======================================================================== FAQ -->
<section class="py-5">
  <div class="container" style="max-width: 760px;">
    <div class="text-center mb-5">
      <span class="sec-eyebrow"><%= t('faq_t') %></span>
      <h2 class="sec-title fw-bold mb-0"><%= t('faq_t') %></h2>
    </div>
    <div class="accordion accordion-flush faq" id="faq">
      <% [1, 2, 3, 4].forEach((n, i) => { %>
        <div class="accordion-item border-0 shadow-sm rounded-4 mb-2 overflow-hidden">
          <h2 class="accordion-header">
            <button class="accordion-button <%= i === 0 ? '' : 'collapsed' %> fw-semibold" type="button"
                    data-bs-toggle="collapse" data-bs-target="#faq<%= n %>">
              <%= t('faq_' + n + '_q') %>
            </button>
          </h2>
          <div id="faq<%= n %>" class="accordion-collapse collapse <%= i === 0 ? 'show' : '' %>" data-bs-parent="#faq">
            <div class="accordion-body text-muted small lh-lg"><%= t('faq_' + n + '_a', { site: settings.siteName }) %></div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- =============================================================== CLOSING CTA -->
<section class="pb-5">
  <div class="container">
    <div class="cta-band text-center px-3 px-md-5 py-5">
      <span class="badge bg-white bg-opacity-25 text-white rounded-pill mb-3 px-3 py-2 d-inline-flex align-items-center gap-1">
        <i data-lucide="alert-triangle"></i><%= t('howto_note') %>
      </span>
      <h2 class="fw-bold mb-2"><%= t('lp_ready_t') %></h2>
      <p class="cta-note mb-4 mx-auto" style="max-width: 46ch;"><%= t('lp_ready_d') %></p>
      <div class="d-flex gap-2 flex-wrap justify-content-center">
        <a href="/signup" class="btn btn-light btn-lg px-4 d-inline-flex align-items-center gap-2">
          <i data-lucide="rocket"></i><%= t('btn_getstarted') %>
        </a>
        <a href="/login" class="btn btn-outline-light btn-lg px-4"><%= t('btn_login') %></a>
      </div>
    </div>
  </div>
</section>
