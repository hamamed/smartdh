<!-- ============ HERO ============ -->
<section class="hero py-5">
  <div class="container py-lg-4">
    <div class="row align-items-center g-5">
      <div class="col-lg-6">
        <span class="badge bg-primary-subtle text-primary rounded-pill mb-3 px-3 py-2 d-inline-flex align-items-center gap-1">
          <i data-lucide="gamepad-2"></i><%= t('hero_badge') %>
        </span>
        <h1 class="display-5 fw-bold mb-3"><%= t('hero_title') %></h1>
        <p class="lead text-muted mb-4"><%= t('hero_desc') %></p>

        <div class="d-flex gap-2 flex-wrap mb-4">
          <a href="/signup" class="btn btn-primary btn-lg px-4 d-inline-flex align-items-center gap-2">
            <i data-lucide="rocket"></i><%= t('btn_getstarted') %>
          </a>
          <a href="/login" class="btn btn-outline-secondary btn-lg px-4"><%= t('btn_login') %></a>
        </div>

        <div class="d-flex flex-wrap gap-2">
          <% [['shield-check','lp_chip_1'], ['gift','lp_chip_2'], ['globe','lp_chip_3']].forEach(([icon, key]) => { %>
            <span class="badge bg-body-secondary text-muted d-inline-flex align-items-center gap-1 p-2">
              <i data-lucide="<%= icon %>"></i><%= t(key) %>
            </span>
          <% }) %>
        </div>
      </div>

      <!-- Earnings calculator -->
      <div class="col-lg-6">
        <div class="card shadow-sm border-0 rounded-4">
          <div class="card-body p-4">
            <h5 class="fw-bold mb-3 d-flex align-items-center gap-2"><i data-lucide="calculator" class="text-primary"></i><%= t('calc_title') %></h5>
            <label class="form-label small text-muted"><%= t('calc_choose_plan') %></label>
            <select id="calcPlan" class="form-select mb-3">
              <% plans.forEach(p => { %>
                <option value="<%= p.ratePer15Days %>" <%= p.id==='balanced'?'selected':'' %>>
                  <%= planName(p) %> — <%= (p.ratePer15Days*100).toFixed(1) %>% <%= t('per15_suffix') %>
                </option>
              <% }) %>
            </select>
            <label class="form-label small text-muted"><%= t('calc_ifinvest') %></label>
            <div class="input-group input-group-lg mb-4">
              <span class="input-group-text"><i data-lucide="wallet"></i></span>
              <input type="number" id="calcAmount" class="form-control" value="10000" min="0" step="100">
              <span class="input-group-text"><%= curLabel %></span>
            </div>
            <div class="row g-3 text-center" data-currency="<%= curLabel %>">
              <div class="col-4"><div class="p-3 rounded-3 wallet wallet-coral">
                <div class="small mb-1"><%= t('lbl_daily') %></div>
                <div class="fw-bold" id="calcDaily">—</div></div></div>
              <div class="col-4"><div class="p-3 rounded-3 wallet wallet-mint">
                <div class="small mb-1"><%= t('lbl_15days') %></div>
                <div class="fw-bold" id="calc15">—</div></div></div>
              <div class="col-4"><div class="p-3 rounded-3 wallet wallet-yellow">
                <div class="small mb-1"><%= t('lbl_monthly') %></div>
                <div class="fw-bold" id="calcMonthly">—</div></div></div>
            </div>
            <p class="small text-muted mt-3 mb-0 d-flex align-items-center gap-1"><i data-lucide="info"></i><%= t('calc_note') %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ LIVE STATS (real data, hidden until there are players) ============ -->
<% if (stats) { %>
  <section class="py-4 bg-body border-top">
    <div class="container">
      <div class="row g-3 text-center">
        <% [
             ['users', 'ti-coral',  stats.players.toLocaleString(), 'stat_players'],
             ['coins', 'ti-mint',   money(stats.coins),             'stat_total'],
             ['layers','ti-sky',    stats.apps,                     'plans_title'],
             ['banknote','ti-yellow', stats.payouts.toLocaleString(), 'lp_stat_payouts']
           ].forEach(([icon, tint, value, key]) => { %>
          <div class="col-6 col-lg-3">
            <span class="tile-icon <%= tint %> mx-auto mb-2" style="width:46px;height:46px;font-size:1.2rem"><i data-lucide="<%= icon %>"></i></span>
            <div class="h5 fw-bold mb-0"><%= value %></div>
            <div class="small text-muted"><%= t(key) %></div>
          </div>
        <% }) %>
      </div>
    </div>
  </section>
<% } %>

<!-- ============ WHAT IS IT ============ -->
<section class="py-5 bg-body border-top">
  <div class="container">
    <div class="text-center mx-auto mb-5" style="max-width: 720px;">
      <h2 class="fw-bold mb-3"><%= t('lp_what_t', { site: settings.siteName }) %></h2>
      <p class="text-muted mb-0 lh-lg"><%= t('lp_what_d') %></p>
    </div>
    <div class="row g-3">
      <%
        const pillars = [
          { icon: 'shield-check', tint: 'mint',   t: 'lp_pillar_1_t', d: 'lp_pillar_1_d' },
          { icon: 'layers',       tint: 'coral',  t: 'lp_pillar_2_t', d: 'lp_pillar_2_d' },
          { icon: 'medal',        tint: 'yellow', t: 'lp_pillar_3_t', d: 'lp_pillar_3_d' }
        ];
      %>
      <% pillars.forEach(p => { %>
        <div class="col-md-4">
          <div class="card border-0 shadow-sm rounded-4 h-100 text-center">
            <div class="card-body p-4">
              <span class="tile-icon ti-<%= p.tint %> mx-auto mb-3" style="width:60px;height:60px;font-size:1.5rem"><i data-lucide="<%= p.icon %>"></i></span>
              <h6 class="fw-bold mb-2"><%= t(p.t) %></h6>
              <p class="text-muted small mb-0"><%= t(p.d) %></p>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ============ HOW IT WORKS ============ -->
<section class="py-5">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="fw-bold mb-1"><%= t('lp_steps_t') %></h2>
      <p class="text-muted mb-0"><%= t('lp_steps_d') %></p>
    </div>
    <div class="row g-3">
      <%
        const steps = [
          { icon: 'user-plus',   text: t('howto_invest_1') },
          { icon: 'layers',      text: t('howto_invest_2', { min: money(settings.minAddFunds) }) },
          { icon: 'shield',      text: t('howto_invest_3') },
          { icon: 'trending-up', text: t('howto_invest_4') }
        ];
      %>
      <% steps.forEach((s, i) => { %>
        <div class="col-md-6 col-lg-3">
          <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-4">
              <div class="d-flex align-items-center gap-2 mb-3">
                <span class="step-num"><%= i + 1 %></span>
                <span class="tile-icon ti-navy" style="width:40px;height:40px;font-size:1.05rem"><i data-lucide="<%= s.icon %>"></i></span>
              </div>
              <p class="text-muted small mb-0"><%= s.text %></p>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ============ WAYS TO EARN ============ -->
<section class="py-5 bg-body border-top">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="fw-bold mb-1"><%= t('howto_earn_t') %></h2>
      <p class="text-muted mb-0"><%= t('lp_earn_d') %></p>
    </div>
    <div class="row g-3">
      <%
        const earn = [
          { icon: 'coins',     tint: 'mint',   t: 'howto_earn_1_t', d: t('howto_earn_1_d') },
          { icon: 'gift',      tint: 'yellow', t: 'howto_earn_2_t', d: t('howto_earn_2_d', { max: money(settings.dailyBonusBase * 7) }) },
          { icon: 'user-plus', tint: 'coral',  t: 'howto_earn_3_t', d: t('howto_earn_3_d', { t1: settings.referralTiers[0]*100, t2: settings.referralTiers[1]*100, t3: settings.referralTiers[2]*100 }) },
          { icon: 'trophy',    tint: 'lilac',  t: 'howto_earn_4_t', d: t('howto_earn_4_d') }
        ];
      %>
      <% earn.forEach(e => { %>
        <div class="col-md-6 col-lg-3">
          <div class="card border-0 shadow-sm rounded-4 h-100 text-center">
            <div class="card-body p-4">
              <span class="tile-icon ti-<%= e.tint %> mx-auto mb-3" style="width:58px;height:58px;font-size:1.5rem"><i data-lucide="<%= e.icon %>"></i></span>
              <h6 class="fw-bold mb-2"><%= t(e.t) %></h6>
              <p class="text-muted small mb-0"><%= e.d %></p>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ============ LEVELS & WITHDRAWALS ============ -->
<section class="py-5">
  <div class="container">
    <h2 class="fw-bold text-center mb-2"><%= t('lp_more_t') %></h2>
    <p class="text-center mb-5">
      <a href="/guide" class="d-inline-flex align-items-center gap-1"><i data-lucide="book-open"></i><%= t('guide_title') %></a>
    </p>
    <div class="row g-3 justify-content-center">
      <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body p-4 d-flex align-items-start gap-3">
            <span class="tile-icon ti-yellow" style="width:48px;height:48px;font-size:1.25rem"><i data-lucide="star"></i></span>
            <div>
              <h6 class="fw-bold mb-2"><%= t('howto_level_t') %></h6>
              <p class="text-muted small mb-0"><%= t('howto_level_d') %></p>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body p-4 d-flex align-items-start gap-3">
            <span class="tile-icon ti-sky" style="width:48px;height:48px;font-size:1.25rem"><i data-lucide="arrow-down-to-line"></i></span>
            <div>
              <h6 class="fw-bold mb-2"><%= t('howto_withdraw_t') %></h6>
              <p class="text-muted small mb-0"><%= t('howto_withdraw_d', { min: money(settings.minWithdraw), days: settings.withdrawEveryDays }) %></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ FAQ ============ -->
<section class="py-5 bg-body border-top">
  <div class="container" style="max-width: 760px;">
    <h2 class="fw-bold text-center mb-5"><%= t('faq_t') %></h2>
    <div class="accordion accordion-flush" id="faq">
      <% [1, 2, 3, 4].forEach((n, i) => { %>
        <div class="accordion-item border-0 shadow-sm rounded-4 mb-2 overflow-hidden">
          <h2 class="accordion-header">
            <button class="accordion-button <%= i === 0 ? '' : 'collapsed' %> fw-semibold" type="button"
                    data-bs-toggle="collapse" data-bs-target="#faq<%= n %>">
              <%= t('faq_' + n + '_q') %>
            </button>
          </h2>
          <div id="faq<%= n %>" class="accordion-collapse collapse <%= i === 0 ? 'show' : '' %>" data-bs-parent="#faq">
            <div class="accordion-body text-muted small"><%= t('faq_' + n + '_a', { site: settings.siteName }) %></div>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- closing note + sign-up nudge -->
    <div class="text-center mt-5">
      <div class="alert alert-warning small d-inline-flex align-items-center gap-2 mb-4">
        <i data-lucide="alert-triangle"></i><span><%= t('howto_note') %></span>
      </div>
      <h5 class="fw-bold mb-1"><%= t('lp_ready_t') %></h5>
      <p class="text-muted small mb-3"><%= t('lp_ready_d') %></p>
      <a href="/signup" class="btn btn-primary px-4 d-inline-flex align-items-center gap-2">
        <i data-lucide="rocket"></i><%= t('btn_getstarted') %>
      </a>
    </div>
  </div>
</section>
