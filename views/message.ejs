<%
  const icon = typeof mIcon !== 'undefined' ? mIcon : 'circle-check';
  const tint = typeof mTint !== 'undefined' ? mTint : 'ti-mint';
  const pending = typeof mPending !== 'undefined' && mPending;
%>
<section class="py-5">
  <div class="container" style="max-width: 560px;">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden text-center">
      <div class="msg-hero">
        <span class="tile-icon <%= tint %>"><i data-lucide="<%= icon %>"></i></span>
      </div>
      <div class="card-body p-4 p-md-5 pt-4">
        <h3 class="fw-bold mb-2"><%= heading %></h3>
        <p class="text-muted mb-0"><%= mBody %></p>

        <% if (pending) { %>
          <div class="msg-steps mt-4">
            <% [['user-check','msg_pend_s1','mint'], ['shield-check','msg_pend_s2','yellow'], ['log-in','msg_pend_s3','sky']].forEach((s, i) => { %>
              <div class="msg-step">
                <span class="tile-icon ti-<%= s[2] %>"><i data-lucide="<%= s[0] %>"></i></span>
                <span class="small fw-semibold mt-2"><%= t(s[1]) %></span>
                <% if (i === 0) { %><span class="badge bg-success-subtle text-success mt-1"><i data-lucide="check"></i></span>
                <% } else if (i === 1) { %><span class="badge bg-warning-subtle text-warning mt-1"><%= t('st_pending') %></span>
                <% } %>
              </div>
              <% if (i < 2) { %><span class="msg-arrow"><i data-lucide="chevron-right"></i></span><% } %>
            <% }) %>
          </div>
        <% } %>

        <div class="d-flex gap-2 justify-content-center flex-wrap mt-4">
          <% if (pending) { %>
            <a href="/login" class="btn btn-primary d-inline-flex align-items-center gap-2"><i data-lucide="log-in"></i><%= t('btn_login') %></a>
          <% } %>
          <% if (typeof mAction !== 'undefined' && mAction) { %>
            <a href="<%= mAction.url %>" class="btn btn-primary d-inline-flex align-items-center gap-2"><i data-lucide="<%= mAction.icon || 'arrow-right' %>"></i><%= mAction.text %></a>
          <% } %>
          <a href="/" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2"><i data-lucide="house"></i><%= t('btn_back_home') %></a>
        </div>
      </div>
    </div>
  </div>
</section>
