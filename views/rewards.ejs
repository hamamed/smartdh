<section class="py-4 py-lg-5">
  <div class="container" style="max-width: 560px;">
    <div class="d-flex align-items-center gap-2 mb-4">
      <a href="/dashboard" class="btn btn-outline-secondary btn-icon rounded-circle"><i data-lucide="arrow-left"></i></a>
      <h3 class="fw-bold mb-0"><%= t('db_title') %></h3>
    </div>

    <div id="flash"></div>

    <div class="card border-0 shadow-sm rounded-4 text-center">
      <div class="card-body p-4">
        <div class="tile-icon ti-yellow mx-auto mb-3" style="width:76px;height:76px;font-size:2rem"><i data-lucide="flame"></i></div>
        <h5 class="fw-bold mb-1"><%= t('streak_line', { n: currentUser.streak.count }) %></h5>
        <p class="text-muted small mb-4"><%= t('bonus_grows', { max: money(settings.dailyBonusBase * 7) }) %></p>
        <form action="/daily-bonus" method="post"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="btn btn-warning btn-lg px-4 d-inline-flex align-items-center gap-2" <%= canClaim ? '' : 'disabled' %>>
            <i data-lucide="gift"></i><%= canClaim ? t('btn_claim') : t('btn_claimed') %>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
